node_modules/
dist/
.astro/
.DS_Store
.env
.env.*
.claude/

# Cover-art import audit log — regenerated on every script run.
cover-art-import-report.txt

# SQLite database file — regenerated by scripts/db-sync.mjs. The
# schema.sql and sync script are the source of truth; the .db is
# build output. Ships to dist/ for client-side admin queries.
data/crfw.db
data/crfw.db-shm
data/crfw.db-wal

# Raw Instagram scrapes produced by scripts/fetch-instagram.sh. Large
# binary dumps; live outside the repo. The importer lifts a curated
# subset into public/media/ and src/content/.
tmp/

# Sync-conflict duplicates. Dropbox appends " 2" / " 3" etc.; iCloud Drive
# (Desktop sync) does the same when multiple devices write simultaneously.
# Cover " 2" through " 9" with a character-class glob so all conflict copies
# are ignored regardless of which digit suffix they carry.
* [2-9].*
* [2-9]
** [2-9].*
** [2-9]
