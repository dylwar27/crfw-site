---
import '../styles/global.css';
interface Props { title?: string; }
const { title = 'Colin Ward / CRFW' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content="An archive and timeline of the work of Colin Ward (CRFW / killd by / alphabets)." />
    <meta name="theme-color" content="#0e0e12" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="An archive and timeline of the work of Colin Ward (CRFW / killd by / alphabets)." />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
