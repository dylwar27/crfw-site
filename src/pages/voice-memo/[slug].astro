---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const memos = await getCollection('voice_memos');
  return memos.map(m => ({
    params: { slug: m.id.replace(/\.json$/, '') },
    props: { memo: m },
  }));
}

const { memo } = Astro.props;
const d = memo.data;
const slug = memo.id.replace(/\.json$/, '');

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
const timelineHref = `${BASE}/`;
const audioSrc = `${BASE}/media/voice-memos/${slug}.m4a`;
const isPublished = d.published !== false;
---

<Base title={`Voice memo — ${d.date} — CRFW`}>
  <article class="memo-page">
    <nav class="memo-nav">
      <a href={timelineHref}>← Back to timeline</a>
    </nav>

    <header class="memo-header">
      <div class="memo-meta">
        <span class="memo-kind">Voice memo</span>
        <span class="memo-date">{d.date}</span>
        {d.project && <span class="memo-project">{d.project}</span>}
      </div>
      <h1 class="memo-title">{d.title ?? 'Voice memo'}</h1>
    </header>

    {isPublished && (
      <section class="memo-player">
        <audio class="memo-audio" controls preload="metadata">
          <source src={audioSrc} type="audio/mp4" />
          <source src={audioSrc} type="audio/m4a" />
          Audio not available in this browser.
        </audio>
      </section>
    )}

    {d.transcript ? (
      <section class="memo-transcript">
        <h2>Transcript</h2>
        <div class="memo-text">
          {d.transcript.split(/\n\n+/).map(para => <p>{para}</p>)}
        </div>
      </section>
    ) : (
      <section class="memo-transcript">
        <p class="memo-no-transcript">No transcript available for this memo.</p>
      </section>
    )}

    {d.archivePath && (
      <aside class="memo-archive">
        <h3>In the archive</h3>
        <code>{d.archivePath}</code>
      </aside>
    )}
  </article>
</Base>

<style>
  .memo-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 48px 32px 96px;
    font-family: var(--sans);
  }
  .memo-nav {
    margin-bottom: 32px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .memo-nav a {
    color: var(--ink-dim);
    text-decoration: none;
  }
  .memo-nav a:hover { color: var(--accent-2); }

  .memo-header {
    margin-bottom: 48px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 24px;
  }
  .memo-meta {
    display: flex;
    gap: 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 16px;
  }
  .memo-meta .memo-kind { color: var(--accent-2); }
  .memo-title {
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .memo-player {
    margin-bottom: 32px;
    padding: 16px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    border-radius: 4px;
  }
  .memo-audio {
    width: 100%;
    display: block;
  }

  .memo-transcript h2 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 16px;
  }
  .memo-text {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink);
  }
  .memo-text p { margin: 0 0 1.2em; }
  .memo-no-transcript { color: var(--ink-dim); font-style: italic; }

  .memo-archive {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .memo-archive h3 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 8px;
  }
  .memo-archive code {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-dim);
    background: var(--bg-soft);
    padding: 8px 12px;
    display: inline-block;
    border: 1px dashed var(--rule);
  }
</style>
