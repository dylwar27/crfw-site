---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Load all the collections
const releases = await getCollection('releases');
const events = await getCollection('events');
const photos = await getCollection('photos');
const videos = await getCollection('videos');
const voice_memos = await getCollection('voice_memos');

// Prefix root-relative asset paths with Astro's configured base (e.g.
// "/crfw-site") so cover art / photo / video posters resolve correctly
// when the site is hosted at a sub-path. When a custom domain lands and
// `base` is set back to '/', this becomes a no-op automatically.
const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
function withBase(p: unknown): string | undefined {
  if (typeof p !== 'string' || !p) return undefined;
  if (p.startsWith('//') || /^[a-z]+:\/\//i.test(p)) return p; // external
  if (!p.startsWith('/')) return p; // relative
  return BASE + p;
}

// Normalize everything into one shape for the timeline
type TLEntry = {
  id: string;
  kind: 'release' | 'event' | 'photo' | 'video' | 'voice_memo';
  title: string;
  preservedTitle?: string;
  date: string;
  year: number;
  project?: string;
  format?: string;
  cover?: string;
  size: 'sm' | 'md' | 'lg' | 'xl';
  tags: string[];
  data: any;
};

const entries: TLEntry[] = [];

for (const r of releases) {
  const year = parseInt(r.data.date.slice(0, 4), 10);
  entries.push({
    id: `release--${r.id.replace(/\.(md|mdx)$/, '')}`,
    kind: 'release',
    title: r.data.title,
    preservedTitle: r.data.preservedTitle,
    date: r.data.date,
    year,
    project: r.data.project,
    format: r.data.format,
    cover: withBase(r.data.coverArt),
    // LPs are big cards; everything else smaller
    size: r.data.format === 'LP' ? 'xl' : r.data.format === 'EP' ? 'lg' : 'md',
    tags: r.data.tags ?? [],
    data: { ...r.data, coverArt: withBase(r.data.coverArt), body: r.body },
  });
}

for (const e of events) {
  const year = parseInt(e.data.date.slice(0, 4), 10);
  entries.push({
    id: `event--${e.id.replace(/\.(md|mdx)$/, '')}`,
    kind: 'event',
    title: e.data.title,
    date: e.data.date,
    year,
    project: e.data.project ?? 'life',
    size: 'sm',
    tags: e.data.tags ?? [],
    data: { ...e.data, body: e.body },
  });
}

for (const p of photos) {
  const year = parseInt((p.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  entries.push({
    id: `photo--${p.id}`,
    kind: 'photo',
    title: p.data.title ?? 'Untitled photo',
    date: p.data.date!,
    year,
    project: p.data.project,
    cover: withBase(p.data.src),
    size: 'sm',
    tags: p.data.tags ?? [],
    data: {
      ...p.data,
      src: withBase(p.data.src),
      carouselExtras: (p.data.carouselExtras ?? []).map(withBase),
    },
  });
}

for (const v of videos) {
  const year = parseInt((v.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  const videoSlug = v.id.replace(/\.json$/, '');
  // Preview first ~200 chars of transcript for the popup. Full text
  // on the /video/<slug> reader page (only generated if transcript
  // >30 chars).
  const hasFullTranscript = !!(v.data.transcript && v.data.transcript.length > 30);
  const transcriptPreview = v.data.transcript
    ? v.data.transcript.slice(0, 200).replace(/\s+/g, ' ').trim() + (v.data.transcript.length > 200 ? '…' : '')
    : undefined;
  const ytThumb = v.data.youtubeId
    ? `https://img.youtube.com/vi/${v.data.youtubeId}/hqdefault.jpg`
    : undefined;
  entries.push({
    id: `video--${v.id}`,
    kind: 'video',
    title: v.data.title,
    date: v.data.date!,
    year,
    project: v.data.project,
    cover: withBase(v.data.poster) || ytThumb,
    size: 'md',
    tags: v.data.tags ?? [],
    data: {
      ...v.data,
      poster: withBase(v.data.poster),
      localSrc: withBase(v.data.localSrc),
      carouselExtras: (v.data.carouselExtras ?? []).map(withBase),
      // Strip full transcript from the inline DATA — keep only the
      // preview (same pattern as voice memos).
      transcript: transcriptPreview,
      transcriptFull: hasFullTranscript,
      permalink: hasFullTranscript ? `${BASE}/video/${videoSlug}` : undefined,
    },
  });
}

for (const m of voice_memos) {
  const year = parseInt(m.data.date.slice(0, 4), 10);
  const memoSlug = m.id.replace(/\.json$/, '');
  // Use first ~200 chars of transcript as in-popup preview.
  // Full transcript lives at /voice-memo/<slug> (a permalinked page).
  const transcriptPreview = m.data.transcript
    ? m.data.transcript.slice(0, 200).replace(/\s+/g, ' ').trim() + (m.data.transcript.length > 200 ? '…' : '')
    : undefined;
  const cardSubtitle = m.data.transcript
    ? m.data.transcript.slice(0, 80).replace(/\s+/g, ' ').trim() + (m.data.transcript.length > 80 ? '…' : '')
    : undefined;
  entries.push({
    id: `voice--${m.id}`,
    kind: 'voice_memo',
    title: m.data.title ?? 'Voice memo',
    preservedTitle: cardSubtitle,
    date: m.data.date,
    year,
    project: m.data.project,
    size: 'sm',
    tags: m.data.tags ?? [],
    // Strip full transcript from inline data — only include preview.
    // Full transcript lives at /voice-memo/<slug>.
    data: {
      ...m.data,
      src: withBase(m.data.src),
      transcript: transcriptPreview,
      transcriptFull: m.data.transcript ? true : false,
      permalink: `${BASE}/voice-memo/${memoSlug}`,
    },
  });
}

// Filter out unpublished entries (they still appear on /admin)
const publishedEntries = entries.filter(e => e.data.published !== false);

// Sort newest first
publishedEntries.sort((a, b) => (b.date.localeCompare(a.date)));

// Group by year (published entries only for the public timeline)
const byYear = new Map<number, TLEntry[]>();
for (const e of publishedEntries) {
  if (!byYear.has(e.year)) byYear.set(e.year, []);
  byYear.get(e.year)!.push(e);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

// ── Bucket system ────────────────────────────────────────────────────────────
type BucketKind =
  | 'release_block' | 'dimcp_chunk' | 'youtube_strip' | 'photo_carousel'
  | 'voice_memo_group' | 'press_strip' | 'unreleased_group' | 'misc';
type TLBucket = { id: string; kind: BucketKind; entries: TLEntry[]; year: number; label?: string; };

function parseEpNum(title: string): number {
  const m = String(title).match(/EP_?(\d+)/i);
  return m ? parseInt(m[1], 10) : 0;
}
function parseSeason(title: string): number {
  const m = String(title).match(/season\s*(\d+)/i);
  return m ? parseInt(m[1], 10) : 1;
}
function isUnreleased(e: TLEntry): boolean {
  return e.tags.includes('unreleased') || e.data.format === 'demo';
}

function bucketYear(entries: TLEntry[], year: number): TLBucket[] {
  const buckets: TLBucket[] = [];
  const relEntries = entries.filter(e => e.kind === 'release' && !isUnreleased(e));
  if (relEntries.length) buckets.push({ id: `rel-block--${year}`, kind: 'release_block', entries: relEntries, year });

  // DIMCP — one bucket per year (broadest grouping, matches voice memo / photo
  // carousel pattern). Earlier per-5-episode chunks produced too many cards.
  const dimcp = entries
    .filter(e => e.kind === 'video' && (e.project || '').toLowerCase() === 'dimcp')
    .sort((a, b) => parseEpNum(a.title) - parseEpNum(b.title));
  if (dimcp.length) {
    buckets.push({
      id: `dimcp--${year}`,
      kind: 'dimcp_chunk',
      entries: dimcp,
      year,
      label: `${dimcp.length} episode${dimcp.length === 1 ? '' : 's'}`,
    });
  }

  const yt = entries.filter(e => e.kind === 'video' && e.data.youtubeId && (e.project || '').toLowerCase() !== 'dimcp');
  if (yt.length) buckets.push({ id: `yt-strip--${year}`, kind: 'youtube_strip', entries: yt, year });

  const media = entries.filter(e =>
    e.kind === 'photo' ||
    (e.kind === 'video' && !e.data.youtubeId && (e.project || '').toLowerCase() !== 'dimcp')
  );
  if (media.length) buckets.push({ id: `photo-carousel--${year}`, kind: 'photo_carousel', entries: media, year });

  const memos = entries.filter(e => e.kind === 'voice_memo');
  const memosByMonth = new Map<string, TLEntry[]>();
  for (const m of memos) {
    const key = (m.date || String(year)).slice(0, 7);
    if (!memosByMonth.has(key)) memosByMonth.set(key, []);
    memosByMonth.get(key)!.push(m);
  }
  for (const [key, ms] of [...memosByMonth.entries()].sort()) {
    const [y, mo] = key.split('-');
    const monthName = new Date(+y, +mo - 1, 1).toLocaleString('en-US', { month: 'long' });
    buckets.push({ id: `vmemo-group--${key}`, kind: 'voice_memo_group', entries: ms, year, label: `${monthName} ${y}` });
  }

  const press = entries.filter(e => e.kind === 'event' && e.tags.includes('press'));
  if (press.length) buckets.push({ id: `press-strip--${year}`, kind: 'press_strip', entries: press, year });

  const unrel = entries.filter(isUnreleased);
  if (unrel.length) buckets.push({ id: `unreleased--${year}`, kind: 'unreleased_group', entries: unrel, year });

  const handled = new Set<string>([...relEntries, ...dimcp, ...yt, ...media, ...memos, ...press, ...unrel].map(e => e.id));
  const misc = entries.filter(e => !handled.has(e.id));
  for (const m of misc) buckets.push({ id: m.id, kind: 'misc', entries: [m], year });

  return buckets;
}

const bucketsByYear = new Map<number, TLBucket[]>();
for (const [year, yEntries] of byYear) bucketsByYear.set(year, bucketYear(yEntries, year));

// Synthetic entry objects for bucket popup data (DIMCP chunks, voice memo groups, photo carousels)
const syntheticEntries: Record<string, any> = {};
for (const [, buckets] of bucketsByYear) {
  for (const b of buckets) {
    if (b.kind === 'dimcp_chunk') {
      syntheticEntries[b.id] = {
        id: b.id, kind: 'dimcp_chunk',
        title: `Dog is My Copilot · ${b.label}`,
        date: String(b.year), year: b.year, project: 'DIMCP',
        size: 'xl', tags: ['dimcp', 'video'],
        data: {
          label: b.label,
          episodes: b.entries.map(e => ({
            id: e.id, title: e.title,
            transcript: (e.data.transcript || '').slice(0, 80),
            slug: e.id.replace(/^video--/, '').replace(/\.json$/, ''),
            permalink: e.data.permalink,
          })),
        },
      };
    } else if (b.kind === 'voice_memo_group') {
      syntheticEntries[b.id] = {
        id: b.id, kind: 'voice_memo_group',
        title: `Voice memos · ${b.label}`,
        date: b.entries[0]?.date || String(b.year), year: b.year,
        size: 'md', tags: ['voice-memo'],
        data: {
          label: b.label,
          memos: b.entries.map(e => ({
            id: e.id, title: e.title,
            transcript: (e.data.transcript || '').slice(0, 80),
            slug: e.id.replace(/^voice--/, '').replace(/\.json$/, ''),
            permalink: e.data.permalink,
          })),
        },
      };
    } else if (b.kind === 'photo_carousel') {
      syntheticEntries[b.id] = {
        id: b.id, kind: 'photo_carousel',
        title: `${b.year} · ${b.entries.length} photo${b.entries.length === 1 ? '' : 's'}`,
        date: String(b.year), year: b.year,
        size: 'lg', tags: ['photo'],
        data: {
          count: b.entries.length,
          photos: b.entries.slice(0, 24).map(e => ({
            id: e.id, src: e.cover, caption: e.data.caption || '',
          })),
        },
      };
    }
  }
}

// Project + medium + format lists for filter dropdowns with counts
function countBy<K extends string>(entries: TLEntry[], key: (e: TLEntry) => K | undefined): Record<string, number> {
  const out: Record<string, number> = {};
  for (const e of entries) {
    const v = key(e);
    if (v == null) continue;
    out[v] = (out[v] ?? 0) + 1;
  }
  return out;
}
const projectCounts = countBy(publishedEntries, e => e.project);
const kindCounts    = countBy(publishedEntries, e => e.kind);
const formatCounts  = countBy(publishedEntries, e => e.format);

const projects = Object.keys(projectCounts).sort((a, b) => projectCounts[b] - projectCounts[a]);
const kinds    = Object.keys(kindCounts);
const formatOrder = ['LP', 'EP', 'single', 'mix', 'compilation', 'b-sides', 'demo', 'other'];
const formats = Object.keys(formatCounts).sort(
  (a, b) => (formatOrder.indexOf(a) === -1 ? 99 : formatOrder.indexOf(a)) - (formatOrder.indexOf(b) === -1 ? 99 : formatOrder.indexOf(b))
);

// Tag list — exclude tags that are redundant with project/kind/format filters
// (e.g. "alphabets", "killd-by", "dimcp", "voice-memo", "video" just echo other axes)
const projectNormalized = new Set(projects.map(p => p.toLowerCase().replace(/\s+/g, '-')));
const kindNormalized = new Set(kinds.map(k => k.replace(/_/g, '-')));
const formatNormalized = new Set(formats.map(f => f.toLowerCase()));
const tagCounts = new Map<string, number>();
for (const e of publishedEntries) {
  for (const t of e.tags) {
    const tl = t.toLowerCase();
    if (projectNormalized.has(tl) || kindNormalized.has(tl) || formatNormalized.has(tl)) continue;
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
// Sort tags by frequency (most common first), cap at top 20 for UI sanity
const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20)
  .map(([t]) => t);

// Totals for the sub-line
const totals = {
  releases: publishedEntries.filter(e => e.kind === 'release').length,
  events: publishedEntries.filter(e => e.kind === 'event').length,
  years: years.length,
  total: publishedEntries.length,
};
---

<Base title="Colin Ward — CRFW Archive">
  <header class="masthead">
    <h1>COLIN <span class="dim">/</span> WARD <span class="dim">/</span> CRFW</h1>
    <div class="sub">
      {totals.total} entries · {totals.releases} releases · {years.length > 0 ? `${years[years.length-1]}–${years[0]}` : ''} · archive in motion
    </div>
  </header>

  <div class="search-bar">
    <input type="search" id="search-input" placeholder="Search the archive…" autocomplete="off" />
    <div id="search-results" class="search-results" hidden></div>
  </div>

  <nav class="filters" id="filters">
    <label class="filter-select">
      <span class="filter-label-text">Project</span>
      <select data-axis="project">
        <option value="all">All ({publishedEntries.length})</option>
        {projects.map(p => (
          <option value={p}>{p} ({projectCounts[p]})</option>
        ))}
      </select>
    </label>

    {formats.length > 0 && (
      <label class="filter-select">
        <span class="filter-label-text">Format</span>
        <select data-axis="format">
          <option value="all">All</option>
          {formats.map(f => (
            <option value={f}>{f} ({formatCounts[f]})</option>
          ))}
        </select>
      </label>
    )}

    {kinds.length >= 2 && (
      <label class="filter-select">
        <span class="filter-label-text">Medium</span>
        <select data-axis="kind">
          <option value="all">All</option>
          {kinds.map(k => (
            <option value={k}>{k.replace('_', ' ')} ({kindCounts[k]})</option>
          ))}
        </select>
      </label>
    )}

    {tags.length > 0 && (
      <label class="filter-select">
        <span class="filter-label-text">Tag</span>
        <select data-axis="tag">
          <option value="all">All</option>
          {tags.map(t => (
            <option value={t}>{t}</option>
          ))}
        </select>
      </label>
    )}

    <button class="filter-reset" id="filter-reset" title="Clear all filters" aria-label="Clear filters">×</button>
    <span class="filter-count" id="filter-count"></span>
  </nav>

  <main class="timeline">
    {years.map(year => (
      <section class="year-row" data-year={year}>
        <div class="year-label">
          {year}
          <span class="after">{byYear.get(year)!.length === 1 ? '1 entry' : `${byYear.get(year)!.length} entries`}</span>
        </div>
        <div class="entries">
          {bucketsByYear.get(year)!.map(bucket =>
            // ── Release block ────────────────────────────────────────────────
            bucket.kind === 'release_block' ? bucket.entries.map(e => (
              <article
                class={`entry release-card size-${e.size}`}
                data-project={e.project}
                data-kind={e.kind}
                data-format={e.format || ''}
                data-tags={e.tags.join('|')}
                data-entry-id={e.id}
              >
                {e.project && <span class="project-tag">{e.project}</span>}
                {e.format && <span class="rel-format-badge">{e.format}</span>}
                {e.cover
                  ? <img class="cover" src={e.cover} alt="" loading="lazy" />
                  : <div class="release-placeholder">
                      <span class="rel-ph-format">{e.format || 'release'}</span>
                      <span class="rel-ph-title">{e.preservedTitle || e.title}</span>
                    </div>
                }
                <div>
                  <div class="title">{e.title}</div>
                  {e.preservedTitle && e.preservedTitle !== e.title && (
                    <div class="preserved">{e.preservedTitle}</div>
                  )}
                </div>
                <div class="medium-tag">{e.format || 'release'} · {e.date.slice(0, 4)}</div>
              </article>
            ))

            // ── DIMCP chunk ──────────────────────────────────────────────────
            : bucket.kind === 'dimcp_chunk' ? (
              <article
                class="entry size-xl dimcp-chunk"
                data-project="DIMCP"
                data-kind="video"
                data-format=""
                data-tags="dimcp|video"
                data-entry-id={bucket.id}
              >
                <span class="project-tag" style="color:#64b5f6;border-color:#64b5f6">DIMCP</span>
                <div class="dimcp-header">
                  Dog is My Copilot
                  <span class="dimcp-label">{bucket.label}</span>
                </div>
                <ol class="dimcp-ep-list">
                  {bucket.entries.slice(0, 6).map(e => (
                    <li class="dimcp-ep-row">
                      <span class="ep-num">EP {String(parseEpNum(e.title)).padStart(2, '0')}</span>
                      <span class="ep-excerpt">{(e.data.transcript || '').slice(0, 70) || e.title}</span>
                    </li>
                  ))}
                  {bucket.entries.length > 6 && (
                    <li class="dimcp-ep-row dimcp-ep-more">
                      <span class="ep-num">+{bucket.entries.length - 6}</span>
                      <span class="ep-excerpt">more — open to view all</span>
                    </li>
                  )}
                </ol>
                <div class="medium-tag">DIMCP · {bucket.entries.length} episodes · {bucket.year}</div>
              </article>
            )

            // ── YouTube strip ────────────────────────────────────────────────
            : bucket.kind === 'youtube_strip' ? bucket.entries.map(e => (
              <article
                class="entry size-md yt-card"
                data-project={e.project || ''}
                data-kind={e.kind}
                data-format={e.format || ''}
                data-tags={e.tags.join('|')}
                data-entry-id={e.id}
              >
                {e.project && <span class="project-tag">{e.project}</span>}
                <div class="yt-thumb-wrap">
                  {e.cover
                    ? <img class="cover" src={e.cover} alt="" loading="lazy" />
                    : <div class="cover yt-thumb-placeholder"></div>
                  }
                  <span class="yt-play-btn" aria-hidden="true">▶</span>
                </div>
                <div>
                  <div class="title">{e.title}</div>
                </div>
                <div class="medium-tag">youtube · {e.date.slice(0, 4)}</div>
              </article>
            ))

            // ── Photo carousel ───────────────────────────────────────────────
            : bucket.kind === 'photo_carousel' ? (
              <article
                class="entry size-lg photo-carousel-card"
                data-project=""
                data-kind="photo"
                data-format=""
                data-tags="photo"
                data-entry-id={bucket.id}
              >
                <div class="photo-preview-strip">
                  {bucket.entries.slice(0, 4).map(p => p.cover && (
                    <img src={p.cover} alt="" loading="lazy" class="photo-thumb-sm" />
                  ))}
                </div>
                <div>
                  <div class="title">{bucket.entries.length} photo{bucket.entries.length === 1 ? '' : 's'}</div>
                </div>
                <div class="medium-tag">photos · {bucket.year}</div>
              </article>
            )

            // ── Voice memo group ─────────────────────────────────────────────
            : bucket.kind === 'voice_memo_group' ? (
              <article
                class="entry size-md voice-memo-group"
                data-project=""
                data-kind="voice_memo"
                data-format=""
                data-tags="voice-memo"
                data-entry-id={bucket.id}
              >
                <div class="vmemo-header">
                  <span class="vmemo-month">{bucket.label}</span>
                  <span class="vmemo-count">{bucket.entries.length} memo{bucket.entries.length === 1 ? '' : 's'}</span>
                </div>
                <ul class="vmemo-preview">
                  {bucket.entries.slice(0, 3).map(e => (
                    <li class="vmemo-row">
                      {(e.data.transcript || e.title || '').slice(0, 65)}
                    </li>
                  ))}
                  {bucket.entries.length > 3 && (
                    <li class="vmemo-more">+{bucket.entries.length - 3} more</li>
                  )}
                </ul>
                <div class="medium-tag">voice memos · {bucket.year}</div>
              </article>
            )

            // ── Press strip ──────────────────────────────────────────────────
            : bucket.kind === 'press_strip' ? bucket.entries.map(e => (
              <article
                class="entry size-sm press-card"
                data-project={e.project || ''}
                data-kind={e.kind}
                data-format={e.format || ''}
                data-tags={e.tags.join('|')}
                data-entry-id={e.id}
              >
                <div class="press-eyebrow">press</div>
                <div class="title">{e.title}</div>
                <div class="medium-tag">{e.date.slice(0, 10)}</div>
              </article>
            ))

            // ── Unreleased group ─────────────────────────────────────────────
            : bucket.kind === 'unreleased_group' ? (
              <article
                class="entry size-md unreleased-group"
                data-project=""
                data-kind="release"
                data-format="unreleased"
                data-tags="unreleased"
                data-entry-id={`unreleased--${bucket.year}`}
              >
                <div class="unrel-header">
                  <span class="unrel-label">Unreleased</span>
                  <span class="unrel-year">{bucket.year}</span>
                </div>
                <ul class="unrel-list">
                  {bucket.entries.slice(0, 5).map(e => (
                    <li class="unrel-row">
                      <span class="unrel-title">{e.title}</span>
                      {e.format && <span class="unrel-fmt">{e.format}</span>}
                    </li>
                  ))}
                  {bucket.entries.length > 5 && (
                    <li class="unrel-more">+{bucket.entries.length - 5} more</li>
                  )}
                </ul>
                <div class="medium-tag">{bucket.entries.length} track{bucket.entries.length === 1 ? '' : 's'} · {bucket.year}</div>
              </article>
            )

            // ── Misc (events, anything else) ─────────────────────────────────
            : bucket.entries.map(e => (
              <article
                class={`entry size-${e.size}`}
                data-project={e.project || ''}
                data-kind={e.kind}
                data-format={e.format || ''}
                data-tags={e.tags.join('|')}
                data-entry-id={e.id}
              >
                {e.project && <span class="project-tag">{e.project}</span>}
                {e.cover && <img class="cover" src={e.cover} alt="" loading="lazy" />}
                <div>
                  <div class="title">{e.title}</div>
                  {e.preservedTitle && e.preservedTitle !== e.title && (
                    <div class="preserved">{e.preservedTitle}</div>
                  )}
                </div>
                <div class="medium-tag">{e.kind.replace('_', ' ')} · {e.date}</div>
              </article>
            ))
          )}
        </div>
      </section>
    ))}
  </main>

  <footer class="foot">
    <div class="foot-nav">
      <a href={`${BASE}/about`}>About</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/projects`}>Projects</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/people`}>People</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/venues`}>Venues</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/orgs`}>Orgs</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/press`}>Press</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/tags`}>Tags</a>
    </div>
    <div class="foot-line">
      CRFW timeline · proof of concept · {totals.total} entries indexed
    </div>
  </footer>

  <!-- popup shell -->
  <div class="popup-scrim" id="popup-scrim" role="dialog" aria-modal="true" aria-labelledby="popup-title">
    <div class="popup" id="popup"></div>
  </div>

  <!-- data payload for popups (server-rendered JSON) -->
  <script id="site-config" type="application/json" data-pagefind-ignore set:html={JSON.stringify({ base: BASE })}></script>

  <script
    id="entry-data"
    type="application/json"
    data-pagefind-ignore
    set:html={JSON.stringify({ ...Object.fromEntries(publishedEntries.map(e => [e.id, e])), ...syntheticEntries })}
  ></script>

  <script is:inline>
    (function () {
      const raw = document.getElementById('entry-data').textContent;
      const DATA = JSON.parse(raw);
      const scrim = document.getElementById('popup-scrim');
      const popup = document.getElementById('popup');

      // --- Relation derivation ---
      // Auto-derive related entries by matching project + year proximity
      // and title substring overlap. Explicit schema references
      // (relatedPhotos/Videos/VoiceMemos) win when present.
      function findRelated(entry) {
        const results = [];
        const seen = new Set([entry.id]);

        function push(other, reason) {
          if (seen.has(other.id)) return;
          seen.add(other.id);
          results.push({ entry: other, reason });
        }

        // 1. Explicit refs from schema
        const d = entry.data || {};
        for (const refList of [d.relatedPhotos, d.relatedVideos, d.relatedVoiceMemos, d.relatedLyrics]) {
          if (!Array.isArray(refList)) continue;
          for (const ref of refList) {
            // refs are {collection, id} objects from Astro
            const id = ref?.id || ref;
            if (typeof id !== 'string') continue;
            // Search by id suffix across DATA
            for (const [key, val] of Object.entries(DATA)) {
              if (key.endsWith(id)) push(val, 'linked');
            }
          }
        }

        // 2. Title substring matches across collections (e.g. release
        //    "SIBERIAN CHILL" matches video "SIBERIAN CHILL.mov").
        // Tightened in Session 08: require 6+ char normalized titles and
        // skip very common placeholder names that match too many things.
        const GENERIC_TITLES = new Set(['untitled', 'recovery', 'alphabets', 'remix', 'demo', 'mix', 'video']);
        const titleNorm = (entry.title || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
        if (titleNorm.length >= 6 && !GENERIC_TITLES.has(titleNorm)) {
          for (const other of Object.values(DATA)) {
            if (other.id === entry.id) continue;
            if (other.kind === entry.kind) continue; // prefer cross-medium matches
            const otherNorm = (other.title || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
            if (otherNorm.length < 6 || GENERIC_TITLES.has(otherNorm)) continue;
            // Bidirectional substring — but require the shorter one to be
            // at least 6 chars. (Prevents "REMIX08" matching every remix.)
            const shorter = otherNorm.length < titleNorm.length ? otherNorm : titleNorm;
            if (shorter.length < 6) continue;
            if (otherNorm.includes(titleNorm) || titleNorm.includes(otherNorm)) {
              push(other, 'title match');
            }
          }
        }

        // 3. Same project + same year (adjacent entries in era)
        if (entry.project && entry.year) {
          for (const other of Object.values(DATA)) {
            if (other.id === entry.id) continue;
            if (other.project !== entry.project) continue;
            if (other.year !== entry.year) continue;
            push(other, 'same project + year');
          }
        }

        return results.slice(0, 8);
      }

      function renderRelated(entry) {
        const related = findRelated(entry);
        if (!related.length) return '';
        const items = related.map(({ entry: r, reason }) => `
          <button class="related-chip" data-entry-id="${escapeHtml(r.id)}" title="${escapeHtml(reason)}">
            <span class="related-kind">${escapeHtml(r.kind.replace('_', ' '))}</span>
            <span class="related-title">${escapeHtml(r.title)}</span>
            <span class="related-date">${escapeHtml(r.date || '')}</span>
          </button>
        `).join('');
        return `<h3>Related in the archive</h3><div class="related-list">${items}</div>`;
      }

      function renderPopup(e) {
        const d = e.data || {};

        // ── DIMCP chunk popup ──────────────────────────────────────────────
        if (e.kind === 'dimcp_chunk') {
          const epRows = (d.episodes || []).map(ep => {
            const vidUrl = ep.permalink || `${BASE_URL}/video/${escapeHtml(ep.slug)}`;
            return `<li class="popup-ep-row">
              <a href="${vidUrl}" class="popup-ep-link">
                <span class="popup-ep-num">${escapeHtml(ep.title.match(/EP_?(\d+)/i)?.[0] ?? ep.title)}</span>
                <span class="popup-ep-excerpt">${escapeHtml(ep.transcript || ep.title)}</span>
                <span class="popup-ep-arrow">→</span>
              </a>
            </li>`;
          }).join('');
          popup.innerHTML = `
            <button class="popup-close" aria-label="Close" id="popup-close">×</button>
            <div class="popup-header">
              <div class="dimcp-popup-icon">🎬</div>
              <div>
                <h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
                <div class="popup-meta"><span>Dog is My Copilot</span><span>${escapeHtml(d.label || '')}</span><span>${(d.episodes||[]).length} episodes</span></div>
              </div>
            </div>
            <ol class="popup-ep-list">${epRows}</ol>
          `;
          popup.querySelector('#popup-close').addEventListener('click', close);
          return;
        }

        // ── Voice memo group popup ─────────────────────────────────────────
        if (e.kind === 'voice_memo_group') {
          const memoRows = (d.memos || []).map(m => {
            const href = m.permalink || `${BASE_URL}/voice-memo/${escapeHtml(m.slug)}`;
            return `<li class="popup-ep-row">
              <a href="${href}" class="popup-ep-link">
                <span class="popup-ep-excerpt">${escapeHtml(m.transcript || m.title)}</span>
                <span class="popup-ep-arrow">→</span>
              </a>
            </li>`;
          }).join('');
          popup.innerHTML = `
            <button class="popup-close" aria-label="Close" id="popup-close">×</button>
            <div class="popup-header">
              <div class="dimcp-popup-icon">🎙</div>
              <div>
                <h2 class="popup-title" id="popup-title">${escapeHtml(d.label || e.title)}</h2>
                <div class="popup-meta"><span>voice memos</span><span>${(d.memos||[]).length} recordings</span></div>
              </div>
            </div>
            <ol class="popup-ep-list">${memoRows}</ol>
          `;
          popup.querySelector('#popup-close').addEventListener('click', close);
          return;
        }

        // ── Photo carousel popup ──────────────────────────────────────────
        if (e.kind === 'photo_carousel') {
          const photos = d.photos || [];
          const thumbs = photos.map((p, i) =>
            `<button class="carousel-grid-thumb${i === 0 ? ' active' : ''}" data-idx="${i}" style="background-image:url('${escapeHtml(p.src || '')}')"></button>`
          ).join('');
          const firstSrc = photos[0]?.src || '';
          popup.innerHTML = `
            <button class="popup-close" aria-label="Close" id="popup-close">×</button>
            <div class="popup-header">
              <div><h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
                <div class="popup-meta"><span>${photos.length} photo${photos.length===1?'':'s'}</span><span>${e.year}</span></div>
              </div>
            </div>
            <div class="popup-photo-main">
              <img id="carousel-main-img" src="${escapeHtml(firstSrc)}" alt="" />
              <p id="carousel-main-cap" class="carousel-main-cap">${escapeHtml(photos[0]?.caption || '')}</p>
            </div>
            <div class="carousel-grid-strip">${thumbs}</div>
          `;
          popup.querySelector('#popup-close').addEventListener('click', close);
          const mainImg = popup.querySelector('#carousel-main-img');
          const mainCap = popup.querySelector('#carousel-main-cap');
          popup.querySelectorAll('.carousel-grid-thumb').forEach(btn => {
            btn.addEventListener('click', () => {
              const idx = +btn.dataset.idx;
              const p = photos[idx];
              if (!p) return;
              mainImg.src = p.src || '';
              mainCap.textContent = p.caption || '';
              popup.querySelectorAll('.carousel-grid-thumb').forEach(b => b.classList.remove('active'));
              btn.classList.add('active');
            });
          });
          return;
        }

        const cover = e.cover || d.coverArt;

        // --- Left-column media (carousel / video / static cover) ---
        const photoSrcs = e.kind === 'photo' && d.src
          ? [d.src, ...(d.carouselExtras || [])]
          : [];
        const isPhotoCarousel = photoSrcs.length > 1;

        let leftColHtml;
        if (photoSrcs.length > 0) {
          leftColHtml = `<div class="popup-carousel-wrap">
            <img class="popup-cover" id="carousel-img" src="${escapeHtml(photoSrcs[0])}" alt="" />
            ${isPhotoCarousel ? `<div class="carousel-nav">
              <button class="carousel-btn" id="carousel-prev" aria-label="Previous" disabled>‹</button>
              <span class="carousel-counter" id="carousel-counter">1 / ${photoSrcs.length}</span>
              <button class="carousel-btn" id="carousel-next" aria-label="Next">›</button>
            </div>` : ''}
          </div>`;
        } else if (e.kind === 'video' && d.localSrc) {
          leftColHtml = `<video class="popup-cover popup-video" controls preload="none"${d.poster ? ` poster="${escapeHtml(d.poster)}"` : ''}>
            <source src="${escapeHtml(d.localSrc)}" type="video/mp4" />
          </video>`;
        } else {
          leftColHtml = cover ? `<img class="popup-cover" src="${escapeHtml(cover)}" alt="" />` : `<div class="popup-cover"></div>`;
        }

        // --- Release-specific: tracklist ---
        const trackHtml = (d.tracklist || []).map(t => `
          <li>
            <span class="n">${t.n ?? ''}</span>
            <span>
              <span class="track-title">${escapeHtml(t.title)}</span>
              ${t.preservedTitle && t.preservedTitle !== t.title
                ? `<span class="track-preserved">${escapeHtml(t.preservedTitle)}</span>`
                : ''}
            </span>
          </li>`).join('');

        // --- Voice memo: transcript preview + link to full reader page ---
        const transcriptHtml = d.transcript
          ? `<h3>Transcript</h3>
             <div class="summary"><p>${escapeHtml(d.transcript)}</p></div>
             ${d.permalink && d.transcriptFull
               ? `<a class="popup-permalink" href="${d.permalink}">Read full transcript →</a>`
               : ''}`
          : '';

        // --- Event: location ---
        const locationHtml = d.location
          ? `<div class="popup-meta"><span>📍 ${escapeHtml(d.location)}</span></div>`
          : '';

        // --- Photo: caption ---
        const captionHtml = d.caption
          ? `<div class="summary"><p>${escapeHtml(d.caption)}</p></div>`
          : '';

        // --- Event: external URL (press articles) ---
        const urlHtml = d.url
          ? `<a class="popup-permalink" href="${escapeHtml(d.url)}" target="_blank" rel="noopener">Read the article →</a>`
          : '';

        // --- Media embeds (release primary), priority BC > YT > SC ---
        // Only the highest-priority available embed is rendered as an
        // iframe; additional platforms show as link chips below.
        const embedLinks = [];
        let primaryEmbedHtml = '';
        if (d.bandcampItemId) {
          const itemType = d.bandcampItemType === 'track' ? 't' : 'a';
          const src = `https://bandcamp.com/EmbeddedPlayer/${itemType}=${escapeHtml(d.bandcampItemId)}/size=large/bgcol=0e0e12/linkcol=ffd166/transparent=true/`;
          primaryEmbedHtml = `<h3>Listen on Bandcamp</h3>
            <div class="embed-wrap"><iframe class="embed-bandcamp" src="${src}" seamless loading="lazy"></iframe></div>`;
        } else if (d.youtubeId) {
          primaryEmbedHtml = `<h3>Watch on YouTube</h3>
            <div class="embed-wrap"><iframe class="embed-youtube" src="https://www.youtube.com/embed/${escapeHtml(d.youtubeId)}" allowfullscreen loading="lazy"></iframe></div>`;
        } else if (d.soundcloudUrl) {
          const src = `https://w.soundcloud.com/player/?url=${encodeURIComponent(d.soundcloudUrl)}&color=%23ffd166&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
          primaryEmbedHtml = `<h3>Listen on SoundCloud</h3>
            <div class="embed-wrap"><iframe class="embed-soundcloud" src="${src}" loading="lazy"></iframe></div>`;
        }
        // Link chips for other platforms when multiple exist
        if (d.bandcampUrl) embedLinks.push(`<a href="${escapeHtml(d.bandcampUrl)}" target="_blank" rel="noopener" class="embed-link">Bandcamp ↗</a>`);
        if (d.youtubeId) embedLinks.push(`<a href="https://www.youtube.com/watch?v=${escapeHtml(d.youtubeId)}" target="_blank" rel="noopener" class="embed-link">YouTube ↗</a>`);
        if (d.soundcloudUrl) embedLinks.push(`<a href="${escapeHtml(d.soundcloudUrl)}" target="_blank" rel="noopener" class="embed-link">SoundCloud ↗</a>`);
        const embedLinksHtml = embedLinks.length > 1
          ? `<div class="embed-links">${embedLinks.join('')}</div>`
          : '';

        const summary = d.summary ? `<div class="summary"><p>${escapeHtml(d.summary)}</p></div>` : '';
        const bodyHtml = d.body ? `<div class="summary">${simpleMarkdown(d.body)}</div>` : '';
        const archive = d.archivePath
          ? `<div class="archive-path">📁 ${escapeHtml(d.archivePath)}</div>` : '';
        const meta = [
          d.date || e.date,
          e.project,
          d.format,
          d.era,
          e.kind,
        ].filter(Boolean).map(m => `<span>${escapeHtml(m)}</span>`).join('');

        popup.innerHTML = `
          <button class="popup-close" aria-label="Close" id="popup-close">×</button>
          <div class="popup-header">
            ${leftColHtml}
            <div>
              <h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
              ${e.preservedTitle && e.preservedTitle !== e.title
                ? `<div class="popup-preserved">${escapeHtml(e.preservedTitle)}</div>` : ''}
              <div class="popup-meta">${meta}</div>
              ${locationHtml}
              ${summary}
              ${captionHtml}
              ${urlHtml}
            </div>
          </div>
          ${primaryEmbedHtml}
          ${embedLinksHtml}
          ${trackHtml ? `<h3>Tracklist</h3><ol class="popup-tracklist">${trackHtml}</ol>` : ''}
          ${transcriptHtml}
          ${bodyHtml ? `<h3>Notes</h3>${bodyHtml}` : ''}
          ${renderRelated(e)}
          ${archive ? `<h3>In the archive</h3>${archive}` : ''}
        `;
        popup.querySelector('#popup-close').addEventListener('click', close);

        // Wire carousel prev/next for photo carousels
        if (isPhotoCarousel) {
          let idx = 0;
          const imgEl = popup.querySelector('#carousel-img');
          const counter = popup.querySelector('#carousel-counter');
          const prevBtn = popup.querySelector('#carousel-prev');
          const nextBtn = popup.querySelector('#carousel-next');
          function goTo(n) {
            idx = n;
            imgEl.src = photoSrcs[idx];
            counter.textContent = `${idx + 1} / ${photoSrcs.length}`;
            prevBtn.disabled = idx === 0;
            nextBtn.disabled = idx === photoSrcs.length - 1;
          }
          prevBtn.addEventListener('click', () => { if (idx > 0) goTo(idx - 1); });
          nextBtn.addEventListener('click', () => { if (idx < photoSrcs.length - 1) goTo(idx + 1); });
        }

        // Wire related-chip clicks → open that entry's popup
        popup.querySelectorAll('.related-chip').forEach(chip => {
          chip.addEventListener('click', () => {
            const id = chip.dataset.entryId;
            if (id && DATA[id]) {
              renderPopup(DATA[id]);
              popup.scrollTo({ top: 0, behavior: 'smooth' });
            }
          });
        });
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[c]));
      }
      const WIKI_ROUTES = { people: '/person', projects: '/project', press: '/press', venues: '/venue', organizations: '/org' };
      const BASE_URL = (JSON.parse(document.getElementById('site-config').textContent || '{}').base || '');
      function resolveWikilink(ref, label) {
        const parts = ref.trim().split('/');
        const coll = parts.length >= 2 ? parts[0] : '';
        const slug = parts.length >= 2 ? parts.slice(1).join('/') : parts[0];
        const display = escapeHtml(label || slug.replace(/-/g, ' '));
        const route = WIKI_ROUTES[coll];
        if (route) return `<a href="${BASE_URL}${route}/${escapeHtml(slug)}" class="wiki-link">${display}</a>`;
        return `<span class="wiki-chip">${display}</span>`;
      }
      function inlineMd(s) {
        const tokens = [];
        const stash = html => { const k = `\x00${tokens.length}\x00`; tokens.push(html); return k; };
        s = s.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, ref, lbl) => stash(resolveWikilink(ref, lbl?.trim() ?? '')));
        s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, (_, lbl, url) => stash(`<a href="${escapeHtml(url)}" target="_blank" rel="noopener">${escapeHtml(lbl)}</a>`));
        s = s.replace(/\*\*([^*\x00]+?)\*\*/g, (_, t) => stash(`<strong>${escapeHtml(t)}</strong>`));
        s = s.replace(/\*([^*\x00]+?)\*/g, (_, t) => stash(`<em>${escapeHtml(t)}</em>`));
        return escapeHtml(s).replace(/\x00(\d+)\x00/g, (_, i) => tokens[+i]);
      }
      function simpleMarkdown(md) {
        return md.split(/\n\n+/).map(block => {
          const t = block.trim();
          if (!t) return '';
          const hm = t.match(/^(#{1,4})\s+(.+)$/);
          if (hm) return `<h4>${escapeHtml(hm[2])}</h4>`;
          if (t.startsWith('> ')) return `<blockquote>${inlineMd(t.replace(/^> ?/gm,''))}</blockquote>`;
          if (/^[-*] /.test(t)) {
            const lis = t.split('\n').filter(l => /^[-*] /.test(l.trim()))
              .map(l => `<li>${inlineMd(l.replace(/^[-*] /,''))}</li>`).join('');
            return `<ul>${lis}</ul>`;
          }
          return `<p>${inlineMd(t.replace(/\n/g,' '))}</p>`;
        }).filter(Boolean).join('');
      }

      function open(id) {
        const e = DATA[id];
        if (!e) return;
        renderPopup(e);
        scrim.setAttribute('open', '');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        scrim.removeAttribute('open');
        document.body.style.overflow = '';
      }
      scrim.addEventListener('click', ev => {
        if (ev.target === scrim) close();
      });
      document.addEventListener('keydown', ev => {
        if (ev.key === 'Escape' && scrim.hasAttribute('open')) close();
      });
      document.querySelectorAll('.entry').forEach(el => {
        el.addEventListener('click', () => open(el.dataset.entryId));
      });

      // Filter tabs — four independent axes (project + kind + format + tag). AND semantics.
      const state = { project: 'all', kind: 'all', format: 'all', tag: 'all' };
      const totalEntries = document.querySelectorAll('.entry').length;
      const filterCount = document.getElementById('filter-count');
      const resetBtn = document.getElementById('filter-reset');

      // Tag dropdown recomputation (Session 11 PR C)
      // Tag options re-scope to entries matching the OTHER axes each
      // time a non-tag filter changes. Prevents the Tag dropdown from
      // listing tags that can't match anything in the current view.
      const tagSelect = document.querySelector('.filter-select select[data-axis="tag"]');
      function recomputeTagOptions() {
        if (!tagSelect) return;
        const previousValue = tagSelect.value;
        const tagCounts = new Map();
        document.querySelectorAll('.entry').forEach(el => {
          const okProj = state.project === 'all' || el.dataset.project === state.project;
          const okKind = state.kind === 'all' || el.dataset.kind === state.kind;
          const okFmt = state.format === 'all' || el.dataset.format === state.format;
          if (!(okProj && okKind && okFmt)) return;
          const tagList = (el.dataset.tags || '').split('|').filter(Boolean);
          for (const t of tagList) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
        });
        // Drop tags redundant with other axes (matching normalization)
        const projVal = state.project === 'all' ? '' : state.project.toLowerCase().replace(/\s+/g, '-');
        const kindVal = state.kind === 'all' ? '' : state.kind.replace(/_/g, '-');
        const formatVal = state.format === 'all' ? '' : state.format.toLowerCase();
        // Sort by frequency, cap at top 30 (5 more than before, because
        // the scoping keeps results relevant)
        const sorted = [...tagCounts.entries()]
          .filter(([t]) => t.toLowerCase() !== projVal && t.toLowerCase() !== kindVal && t.toLowerCase() !== formatVal)
          .sort((a, b) => b[1] - a[1])
          .slice(0, 30);
        // Rebuild options
        const lines = ['<option value="all">All</option>'];
        for (const [tag, count] of sorted) {
          const escTag = tag.replace(/"/g, '&quot;');
          lines.push(`<option value="${escTag}">${escTag} (${count})</option>`);
        }
        tagSelect.innerHTML = lines.join('');
        // Restore previous value if still valid, else reset
        if ([...tagSelect.options].some(o => o.value === previousValue)) {
          tagSelect.value = previousValue;
        } else {
          tagSelect.value = 'all';
          state.tag = 'all';
          tagSelect.closest('.filter-select').classList.remove('active');
        }
      }

      function applyFilters(opts) {
        opts = opts || {};
        let visible = 0;
        document.querySelectorAll('.entry').forEach(el => {
          const okProj = state.project === 'all' || el.dataset.project === state.project;
          const okKind = state.kind === 'all' || el.dataset.kind === state.kind;
          const okFmt = state.format === 'all' || el.dataset.format === state.format;
          const tagList = (el.dataset.tags || '').split('|').filter(Boolean);
          const okTag = state.tag === 'all' || tagList.includes(state.tag);
          const show = okProj && okKind && okFmt && okTag;
          el.hidden = !show;
          if (show) visible++;
        });
        // Update year row visibility and entry counts
        document.querySelectorAll('.year-row').forEach(row => {
          const count = row.querySelectorAll('.entry:not([hidden])').length;
          row.style.display = count ? '' : 'none';
          const after = row.querySelector('.year-label .after');
          if (after) after.textContent = count + (count === 1 ? ' entry' : ' entries');
        });
        // Show filter count when filtering is active
        const isFiltered = state.project !== 'all' || state.kind !== 'all' || state.format !== 'all' || state.tag !== 'all';
        if (filterCount) {
          filterCount.textContent = isFiltered
            ? `showing ${visible} of ${totalEntries}`
            : '';
        }
        if (resetBtn) {
          resetBtn.style.display = isFiltered ? '' : 'none';
        }
        // Recompute tag scope after other filters change
        if (!opts.skipTagRecompute) recomputeTagOptions();
      }

      // Dropdowns (Session 11) — replaced chip buttons with <select>s
      document.querySelectorAll('.filter-select select').forEach(sel => {
        sel.addEventListener('change', () => {
          const axis = sel.dataset.axis;
          state[axis] = sel.value;
          // Highlight dropdown when non-"all"
          sel.closest('.filter-select').classList.toggle('active', sel.value !== 'all');
          // Skip tag recompute when the tag dropdown itself changed
          applyFilters({ skipTagRecompute: axis === 'tag' });
        });
      });

      // URL param pre-selection: /?project=X&tag=Y etc.
      const qs = new URLSearchParams(window.location.search);
      for (const axis of ['project', 'kind', 'format', 'tag']) {
        const v = qs.get(axis);
        if (!v) continue;
        const sel = document.querySelector(`.filter-select select[data-axis="${axis}"]`);
        if (!sel) continue;
        // Tag axis may need its option to exist — rebuild first then set
        if (axis === 'tag') {
          recomputeTagOptions();
          if (![...sel.options].some(o => o.value === v)) {
            // Tag not in top 30 after other filters applied — add it
            const opt = document.createElement('option');
            opt.value = v; opt.textContent = v;
            sel.appendChild(opt);
          }
        }
        if ([...sel.options].some(o => o.value === v)) {
          sel.value = v;
          state[axis] = v;
          sel.closest('.filter-select').classList.add('active');
        }
      }
      applyFilters();

      // --- Pagefind search ---
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      let pagefind = null;
      let searchDebounce;

      async function ensurePagefind() {
        if (pagefind) return pagefind;
        try {
          // Pagefind generates /pagefind/pagefind.js at build time
          const base = (window.location.pathname.match(/^\/[^/]+\//) || ['/'])[0];
          pagefind = await import(/* @vite-ignore */ `${base}pagefind/pagefind.js`);
          await pagefind.options({ baseUrl: base });
          return pagefind;
        } catch (err) {
          console.warn('Pagefind not available yet (run npm run build first):', err);
          return null;
        }
      }

      async function runSearch(query) {
        if (!query || query.length < 2) {
          searchResults.hidden = true;
          searchResults.innerHTML = '';
          return;
        }
        const pf = await ensurePagefind();
        if (!pf) {
          searchResults.hidden = false;
          searchResults.innerHTML = '<div class="search-empty">Search unavailable (dev mode — rebuild to enable)</div>';
          return;
        }
        const search = await pf.search(query);
        const firstTen = await Promise.all(search.results.slice(0, 10).map(r => r.data()));
        searchResults.hidden = false;
        if (!firstTen.length) {
          searchResults.innerHTML = `<div class="search-empty">No results for “${escapeHtml(query)}”</div>`;
          return;
        }
        searchResults.innerHTML = firstTen.map(r => `
          <a class="search-hit" href="${r.url}">
            <div class="search-hit-title">${r.meta?.title || r.url}</div>
            <div class="search-hit-excerpt">${r.excerpt}</div>
          </a>
        `).join('');
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          clearTimeout(searchDebounce);
          const q = searchInput.value.trim();
          searchDebounce = setTimeout(() => runSearch(q), 200);
        });
        searchInput.addEventListener('blur', () => {
          // Hide results after a moment to allow clicks through
          setTimeout(() => { searchResults.hidden = true; }, 200);
        });
        searchInput.addEventListener('focus', () => {
          if (searchInput.value.trim().length >= 2) searchResults.hidden = false;
        });
      }

      // Reset all filters
      if (resetBtn) {
        resetBtn.style.display = 'none'; // hidden on load
        resetBtn.addEventListener('click', () => {
          state.project = 'all';
          state.kind = 'all';
          state.format = 'all';
          state.tag = 'all';
          document.querySelectorAll('.filter-select select').forEach(sel => {
            sel.value = 'all';
            sel.closest('.filter-select').classList.remove('active');
          });
          applyFilters();
        });
      }
    })();
  </script>
</Base>
