---
/**
 * Motif walk landing page.
 *
 * Quiet hero + an infinite-scroll stream of individual entries pulled
 * across all years. The next card is selected by relatedness scoring
 * (motif/series/project/decade/kind) against the most recently shown
 * card, falling back to a random unseen entry. The dense year-bucketed
 * timeline lives at /timeline; this page is the contemplative default.
 */
import Base from '../layouts/Base.astro';
import PopupShell from '../components/PopupShell.astro';
import TopNav from '../components/TopNav.astro';
import { getCollection } from 'astro:content';
import {
  buildMotifIndex,
  buildSeriesIndex,
  buildWalkFeed,
} from '../lib/walkFeed';

const releases = await getCollection('releases');
const videos = await getCollection('videos');
const voice_memos = await getCollection('voice_memos');
const photos = await getCollection('photos');
const events = await getCollection('events');
const vault_series = await getCollection('vault_series');
const vault_motifs = await getCollection('vault_motifs');
const vault_tracks = await getCollection('vault_tracks');

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
function withBase(p: unknown): string | undefined {
  if (typeof p !== 'string' || !p) return undefined;
  if (p.startsWith('//') || /^[a-z]+:\/\//i.test(p)) return p;
  if (!p.startsWith('/')) return p;
  return BASE + p;
}

const motifsByEntry = buildMotifIndex(vault_motifs as any, vault_tracks as any);
const seriesByEntry = buildSeriesIndex(vault_series as any);

const walkFeed = buildWalkFeed({
  releases: releases as any,
  videos: videos as any,
  voice_memos: voice_memos as any,
  photos: photos as any,
  motifsByEntry,
  seriesByEntry,
  withBase,
});

// ── Build the popup payload (mirrors timeline.astro entry shapes) ───────
// Every entry in walkFeed needs a corresponding entry in #entry-data so
// PopupShell can render its popup on click. We rebuild the same TLEntry
// shape used by timeline.astro, keyed by entry id.
type PopupEntry = {
  id: string;
  kind: string;
  title: string;
  preservedTitle?: string;
  date: string;
  year: number;
  project?: string;
  format?: string;
  cover?: string;
  size?: string;
  tags: string[];
  series?: string[];
  data: any;
};

const popupEntries: Record<string, PopupEntry> = {};

for (const r of releases) {
  if (r.data.published === false) continue;
  const id = `release--${r.id.replace(/\.(md|mdx)$/, '')}`;
  const year = parseInt(r.data.date.slice(0, 4), 10);
  popupEntries[id] = {
    id, kind: 'release',
    title: r.data.title,
    preservedTitle: r.data.preservedTitle,
    date: r.data.date,
    year,
    project: r.data.project,
    format: r.data.format,
    cover: withBase(r.data.coverArt),
    tags: r.data.tags ?? [],
    data: { ...r.data, coverArt: withBase(r.data.coverArt), body: r.body },
  };
}

for (const e of events) {
  if (e.data.published === false) continue;
  const id = `event--${e.id.replace(/\.(md|mdx)$/, '')}`;
  const year = parseInt(e.data.date.slice(0, 4), 10);
  popupEntries[id] = {
    id, kind: 'event',
    title: e.data.title,
    date: e.data.date,
    year,
    project: e.data.project ?? 'life',
    tags: e.data.tags ?? [],
    data: { ...e.data, body: e.body },
  };
}

for (const p of photos) {
  if (p.data.published === false) continue;
  const year = parseInt((p.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  const id = `photo--${p.id}`;
  popupEntries[id] = {
    id, kind: 'photo',
    title: p.data.title ?? 'Untitled photo',
    date: p.data.date!,
    year,
    project: p.data.project,
    cover: withBase(p.data.src),
    tags: p.data.tags ?? [],
    data: {
      ...p.data,
      src: withBase(p.data.src),
      carouselExtras: (p.data.carouselExtras ?? []).map(withBase),
    },
  };
}

for (const v of videos) {
  if (v.data.published === false) continue;
  const year = parseInt((v.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  const videoSlug = v.id.replace(/\.json$/, '');
  const hasFullTranscript = !!(v.data.transcript && v.data.transcript.length > 30);
  const transcriptPreview = v.data.transcript
    ? v.data.transcript.slice(0, 200).replace(/\s+/g, ' ').trim() + (v.data.transcript.length > 200 ? '…' : '')
    : undefined;
  const ytThumb = v.data.youtubeId
    ? `https://img.youtube.com/vi/${v.data.youtubeId}/hqdefault.jpg`
    : undefined;
  const id = `video--${v.id}`;
  popupEntries[id] = {
    id, kind: 'video',
    title: v.data.title,
    date: v.data.date!,
    year,
    project: v.data.project,
    cover: withBase(v.data.poster) || ytThumb,
    tags: v.data.tags ?? [],
    data: {
      ...v.data,
      poster: withBase(v.data.poster),
      localSrc: withBase(v.data.localSrc),
      carouselExtras: (v.data.carouselExtras ?? []).map(withBase),
      transcript: transcriptPreview,
      transcriptFull: hasFullTranscript,
      permalink: hasFullTranscript ? `${BASE}/video/${videoSlug}` : undefined,
    },
  };
}

for (const m of voice_memos) {
  if (m.data.published === false) continue;
  const year = parseInt(m.data.date.slice(0, 4), 10);
  const memoSlug = m.id.replace(/\.json$/, '');
  const transcriptPreview = m.data.transcript
    ? m.data.transcript.slice(0, 200).replace(/\s+/g, ' ').trim() + (m.data.transcript.length > 200 ? '…' : '')
    : undefined;
  const cardSubtitle = m.data.transcript
    ? m.data.transcript.slice(0, 80).replace(/\s+/g, ' ').trim() + (m.data.transcript.length > 80 ? '…' : '')
    : undefined;
  const id = `voice--${m.id}`;
  popupEntries[id] = {
    id, kind: 'voice_memo',
    title: m.data.title ?? 'Voice memo',
    preservedTitle: cardSubtitle,
    date: m.data.date,
    year,
    project: m.data.project,
    tags: m.data.tags ?? [],
    data: {
      ...m.data,
      src: withBase(m.data.src),
      transcript: transcriptPreview,
      transcriptFull: m.data.transcript ? true : false,
      permalink: `${BASE}/voice-memo/${memoSlug}`,
    },
  };
}

const totalCount = walkFeed.length;
---
<Base title="Colin Ward / CRFW">
  <TopNav current="walk" />

  <header class="walk-hero">
    <h1>Colin Ward</h1>
    <p class="walk-hero-sub">CRFW / killd by / alphabets · 1990–2018</p>
    <p class="walk-hero-hint">
      Scroll to remember through motifs, episodes, recordings, photographs,
      and recordings.<br/>
      Up top for organized views.
    </p>
  </header>

  <main class="walk-stream" id="walk-stream" aria-label="Motif walk">
    <!-- Cards are inserted client-side from the walk feed. -->
  </main>

  <div class="walk-sentinel" id="walk-sentinel" aria-hidden="true"></div>

  <footer class="foot walk-foot">
    <div class="foot-nav">
      <a href={`${BASE}/timeline`}>Timeline</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/motifs`}>Motifs</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/people`}>People</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/press`}>Press</a>
      <span class="foot-sep">·</span>
      <a href={`${BASE}/about`}>About</a>
    </div>
    <div class="foot-line">
      a memorial archive · {totalCount} entries in the walk
    </div>
  </footer>

  <PopupShell entries={popupEntries} />

  <script
    id="walk-feed"
    type="application/json"
    data-pagefind-ignore
    set:html={JSON.stringify(walkFeed)}
  ></script>

  <script is:inline>
    (function () {
      const FEED = JSON.parse(document.getElementById('walk-feed').textContent);
      const stream = document.getElementById('walk-stream');
      const sentinel = document.getElementById('walk-sentinel');
      if (!FEED.length || !stream || !sentinel) return;

      const BATCH_FIRST = 9;
      const BATCH_MORE = 9;
      const seen = new Set();
      let current = null;
      // Sliding window of the last 6 kinds shown, used to penalise same-kind
      // repetition and force type cycling (photo/video/voice_memo/release).
      const recentKinds = [];

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[c]));
      }

      function shareSome(a, b) {
        if (!a || !b || !a.length || !b.length) return false;
        for (const x of a) if (b.includes(x)) return true;
        return false;
      }

      function score(curr, cand) {
        if (!curr) return Math.random();
        if (cand.id === curr.id) return -1;
        let s = 0;
        if (shareSome(curr.motifs, cand.motifs)) s += 10;
        if (shareSome(curr.series, cand.series)) s += 5;
        if (curr.project && cand.project && curr.project === cand.project) s += 3;
        if (curr.year && cand.year && Math.floor(curr.year / 10) === Math.floor(cand.year / 10)) s += 1;
        if (curr.kind === cand.kind) s += 0.5;
        return s + Math.random() * 0.01; // tie-break jitter
      }

      function pickNext() {
        if (seen.size >= FEED.length) { seen.clear(); recentKinds.length = 0; }
        // Count how often each kind appears in the recent window.
        const kindFreq = {};
        for (const k of recentKinds) kindFreq[k] = (kindFreq[k] || 0) + 1;
        let best = null, bestScore = -999;
        for (const cand of FEED) {
          if (seen.has(cand.id)) continue;
          // Base relatedness score + tie-break jitter.
          let s = score(current, cand);
          // Penalise kinds seen recently to force type cycling across
          // release / video / voice_memo / photo. 2.5 pts per recent
          // occurrence means a kind shown 3× in the last 6 cards needs
          // a +7.5 signal (nearly a motif match) to re-appear.
          s -= (kindFreq[cand.kind] || 0) * 2.5;
          if (s > bestScore) { bestScore = s; best = cand; }
        }
        return best || FEED[Math.floor(Math.random() * FEED.length)];
      }

      function pickInitial() {
        const i = Math.floor(Math.random() * FEED.length);
        return FEED[i];
      }

      function metaLine(entry) {
        const parts = [];
        if (entry.year) parts.push(String(entry.year));
        if (entry.project) parts.push(entry.project);
        const kindLabel = entry.kind === 'voice_memo' ? 'voice memo' : entry.kind;
        parts.push(kindLabel);
        return parts.join(' · ');
      }

      function renderCard(entry) {
        const card = document.createElement('article');
        card.className = `entry walk-card walk-card-${entry.kind}`;
        card.dataset.entryId = entry.id;
        card.dataset.kind = entry.kind;
        if (entry.project) card.dataset.project = entry.project;
        if (entry.tags && entry.tags.length) card.dataset.tags = entry.tags.join('|');

        const meta = `<div class="walk-meta">${escapeHtml(metaLine(entry))}</div>`;

        let inner = '';
        if (entry.kind === 'release') {
          const cover = entry.cover
            ? `<img class="walk-cover" loading="lazy" src="${escapeHtml(entry.cover)}" alt="" />`
            : `<div class="walk-cover walk-cover-placeholder"></div>`;
          // Bandcamp inline play wrapper if release has a bandcampItemId
          const bcId = entry.bandcampItemId;
          const bcType = entry.bandcampItemType || 'album';
          const coverWrap = bcId
            ? `<div class="bc-inline-play walk-media" data-bc-item-id="${escapeHtml(bcId)}" data-bc-item-type="${escapeHtml(bcType)}" data-bc-title="${escapeHtml(entry.title)}" title="Click to play">${cover}</div>`
            : `<div class="walk-media">${cover}</div>`;
          const preserved = entry.preservedTitle && entry.preservedTitle !== entry.title
            ? `<div class="walk-preserved">${escapeHtml(entry.preservedTitle)}</div>`
            : '';
          inner = `${coverWrap}
            <div class="walk-body">
              <div class="walk-kind">release</div>
              <h2 class="walk-title">${escapeHtml(entry.title)}</h2>
              ${preserved}
              ${meta}
            </div>`;
        } else if (entry.kind === 'video') {
          const cover = entry.cover
            ? `<img class="walk-cover" loading="lazy" src="${escapeHtml(entry.cover)}" alt="" />`
            : `<div class="walk-cover walk-cover-placeholder"></div>`;
          const ytId = entry.ytId;
          const coverWrap = ytId
            ? `<div class="yt-inline-play walk-media" data-yt-id="${escapeHtml(ytId)}" data-yt-title="${escapeHtml(entry.title)}" title="Click to play">${cover}<button class="yt-play-btn" type="button" aria-label="Play"><span>▶</span></button></div>`
            : `<div class="walk-media">${cover}</div>`;
          inner = `${coverWrap}
            <div class="walk-body">
              <div class="walk-kind">video</div>
              <h2 class="walk-title">${escapeHtml(entry.title)}</h2>
              ${meta}
            </div>`;
        } else if (entry.kind === 'voice_memo') {
          inner = `<div class="walk-media walk-media-vmemo">
              <div class="walk-vmemo-mono">VOICE MEMO · ${escapeHtml(entry.date.slice(0, 10))}</div>
              <div class="walk-vmemo-bubble">▶ open recording</div>
            </div>
            <div class="walk-body">
              <div class="walk-kind">voice memo</div>
              <h2 class="walk-title">${escapeHtml(entry.title)}</h2>
              ${meta}
            </div>`;
        } else if (entry.kind === 'photo') {
          // Photos: load just the photo, with caption-as-title if available.
          const isVisualArt = entry.tags && entry.tags.includes('visual-art');
          const img = entry.cover
            ? `<img class="walk-photo${isVisualArt ? ' walk-photo-art' : ''}" loading="lazy" src="${escapeHtml(entry.cover)}" alt="${escapeHtml(entry.title)}" />`
            : `<div class="walk-cover walk-cover-placeholder"></div>`;
          const titleLine = entry.title && entry.title !== 'Untitled photo'
            ? `<h2 class="walk-title walk-title-quiet">${escapeHtml(entry.title)}</h2>`
            : '';
          inner = `<div class="walk-media walk-media-photo">${img}</div>
            <div class="walk-body walk-body-quiet">
              ${titleLine}
              ${meta}
            </div>`;
        } else {
          // Event / other — minimal
          inner = `<div class="walk-body">
              <div class="walk-kind">${escapeHtml(entry.kind)}</div>
              <h2 class="walk-title">${escapeHtml(entry.title)}</h2>
              ${meta}
            </div>`;
        }

        card.innerHTML = inner;
        return card;
      }

      function renderOne(entry) {
        if (!entry || seen.has(entry.id)) return;
        seen.add(entry.id);
        recentKinds.push(entry.kind);
        if (recentKinds.length > 6) recentKinds.shift();
        current = entry;
        stream.appendChild(renderCard(entry));
      }

      function renderBatch(n) {
        if (!current) {
          const seed = pickInitial();
          renderOne(seed);
          n -= 1;
        }
        for (let i = 0; i < n; i++) {
          const next = pickNext();
          if (!next) break;
          renderOne(next);
        }
      }

      // Initial fill
      renderBatch(BATCH_FIRST);

      // Infinite scroll: append more when sentinel approaches.
      let appending = false;
      const io = new IntersectionObserver((entries) => {
        for (const ent of entries) {
          if (ent.isIntersecting && !appending) {
            appending = true;
            requestAnimationFrame(() => {
              renderBatch(BATCH_MORE);
              appending = false;
            });
          }
        }
      }, { rootMargin: '600px 0px' });
      io.observe(sentinel);
    })();
  </script>

  <style>
    /* Walk-only styles. The .entry / popup styles are inherited from
       global.css so cards open the same popups as the timeline.
       Top-nav styles live in TopNav.astro. */
    body { background: var(--bg, #0e0e12); color: var(--ink, #e8e6e1); }

    .walk-hero {
      max-width: 1120px; margin: 0 auto;
      padding: 64px 24px 32px;
      text-align: left;
    }
    .walk-hero h1 {
      font-family: var(--serif, Georgia, serif);
      font-weight: 900;
      font-size: clamp(40px, 8vw, 76px);
      letter-spacing: -0.02em; line-height: 1.02;
      margin: 0 0 8px;
    }
    .walk-hero-sub {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--ink-dim, #a8a39d);
      margin: 0 0 20px;
    }
    .walk-hero-hint {
      font-family: var(--serif, Georgia, serif);
      font-size: 17px; line-height: 1.55;
      color: var(--ink-dim, #a8a39d);
      max-width: 560px; margin: 0;
    }

    .walk-stream {
      max-width: 1120px; margin: 0 auto;
      padding: 24px 16px 96px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 48px 28px;
      align-items: start;
    }
    .walk-card {
      display: flex; flex-direction: column; gap: 12px;
      cursor: pointer;
      animation: walk-fade-in 0.4s ease-out;
    }
    .walk-card .walk-media { position: relative; line-height: 0; }
    .walk-card .walk-cover, .walk-card .walk-photo {
      width: 100%; height: auto; display: block;
      background: #1a1a20;
    }
    .walk-card .walk-photo-art { object-fit: contain; max-height: 80vh; }
    .walk-card .walk-cover-placeholder {
      aspect-ratio: 1; background: #1a1a20;
    }
    .walk-card .walk-body { display: flex; flex-direction: column; gap: 6px; }
    .walk-card .walk-body-quiet { gap: 4px; opacity: 0.85; }
    .walk-card .walk-kind {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--ink-dim, #a8a39d);
    }
    .walk-card .walk-title {
      font-family: var(--serif, Georgia, serif);
      font-weight: 800; font-size: 22px; line-height: 1.25;
      letter-spacing: -0.01em;
      margin: 0; color: var(--ink, #e8e6e1);
    }
    .walk-card .walk-title-quiet { font-size: 16px; font-weight: 600; opacity: 0.9; }
    .walk-card .walk-preserved {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 13px; color: var(--accent-2, #ffd166);
    }
    .walk-card .walk-meta {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-dim, #a8a39d);
    }

    /* Voice memo placeholder card — minimal until popup */
    .walk-card .walk-media-vmemo {
      background: #161620;
      border: 1px solid var(--rule);
      padding: 32px 18px;
      display: flex; flex-direction: column; gap: 10px;
      align-items: flex-start;
    }
    .walk-card .walk-vmemo-mono {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ink-dim, #a8a39d);
    }
    .walk-card .walk-vmemo-bubble {
      font-family: var(--mono, ui-monospace, monospace);
      font-size: 14px; color: var(--accent-2, #ffd166);
    }

    /* YT inline play visual cue (button overlay) — same .yt-play-btn class
       used on timeline so the existing styles in global.css apply. */
    .walk-card .yt-inline-play { cursor: pointer; }

    /* Bandcamp inline-play hover state */
    .walk-card .bc-inline-play { cursor: pointer; }

    .walk-sentinel {
      height: 1px; width: 100%;
    }

    .walk-foot {
      max-width: 1120px; margin: 0 auto;
      padding: 32px 16px 48px;
      text-align: left;
      border-top: 1px solid var(--rule);
    }

    /* Photos can be very tall — cap them so one photo doesn't dominate a grid row */
    .walk-card .walk-photo { max-height: 60vh; object-fit: cover; width: 100%; }
    .walk-card .walk-photo-art { max-height: 70vh; object-fit: contain; }

    @media (max-width: 620px) {
      .walk-stream { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      .walk-card { animation: none; }
    }
    @keyframes walk-fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: none; }
    }
  </style>
</Base>
