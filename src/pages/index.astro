---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Load all the collections
const releases = await getCollection('releases');
const events = await getCollection('events');
const photos = await getCollection('photos');
const videos = await getCollection('videos');
const voice_memos = await getCollection('voice_memos');

// Normalize everything into one shape for the timeline
type TLEntry = {
  id: string;
  kind: 'release' | 'event' | 'photo' | 'video' | 'voice_memo';
  title: string;
  preservedTitle?: string;
  date: string;
  year: number;
  project?: string;
  cover?: string;
  size: 'sm' | 'md' | 'lg' | 'xl';
  tags: string[];
  data: any;
};

const entries: TLEntry[] = [];

for (const r of releases) {
  const year = parseInt(r.data.date.slice(0, 4), 10);
  entries.push({
    id: `release--${r.id.replace(/\.(md|mdx)$/, '')}`,
    kind: 'release',
    title: r.data.title,
    preservedTitle: r.data.preservedTitle,
    date: r.data.date,
    year,
    project: r.data.project,
    cover: r.data.coverArt,
    // LPs are big cards; everything else smaller
    size: r.data.format === 'LP' ? 'xl' : r.data.format === 'EP' ? 'lg' : 'md',
    tags: r.data.tags ?? [],
    data: { ...r.data, body: r.body },
  });
}

for (const e of events) {
  const year = parseInt(e.data.date.slice(0, 4), 10);
  entries.push({
    id: `event--${e.id.replace(/\.(md|mdx)$/, '')}`,
    kind: 'event',
    title: e.data.title,
    date: e.data.date,
    year,
    project: e.data.project ?? 'life',
    size: 'sm',
    tags: e.data.tags ?? [],
    data: { ...e.data, body: e.body },
  });
}

for (const p of photos) {
  const year = parseInt((p.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  entries.push({
    id: `photo--${p.id}`,
    kind: 'photo',
    title: p.data.title ?? 'Untitled photo',
    date: p.data.date!,
    year,
    project: p.data.project,
    cover: p.data.src,
    size: 'sm',
    tags: p.data.tags ?? [],
    data: p.data,
  });
}

for (const v of videos) {
  const year = parseInt((v.data.date ?? '0000').slice(0, 4), 10);
  if (!year) continue;
  entries.push({
    id: `video--${v.id}`,
    kind: 'video',
    title: v.data.title,
    date: v.data.date!,
    year,
    project: v.data.project,
    cover: v.data.poster,
    size: 'md',
    tags: v.data.tags ?? [],
    data: v.data,
  });
}

for (const m of voice_memos) {
  const year = parseInt(m.data.date.slice(0, 4), 10);
  entries.push({
    id: `voice--${m.id}`,
    kind: 'voice_memo',
    title: m.data.title ?? 'Voice memo',
    date: m.data.date,
    year,
    project: m.data.project,
    size: 'sm',
    tags: m.data.tags ?? [],
    data: m.data,
  });
}

// Sort newest first
entries.sort((a, b) => (b.date.localeCompare(a.date)));

// Group by year
const byYear = new Map<number, TLEntry[]>();
for (const e of entries) {
  if (!byYear.has(e.year)) byYear.set(e.year, []);
  byYear.get(e.year)!.push(e);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

// Project + medium lists for filter tabs
const projects = [...new Set(entries.map(e => e.project).filter(Boolean))] as string[];
const kinds = [...new Set(entries.map(e => e.kind))];

// Totals for the sub-line
const totals = {
  releases: entries.filter(e => e.kind === 'release').length,
  events: entries.filter(e => e.kind === 'event').length,
  years: years.length,
  total: entries.length,
};
---

<Base title="Colin Ward — CRFW Archive">
  <header class="masthead">
    <h1>COLIN <span class="dim">/</span> WARD <span class="dim">/</span> CRFW</h1>
    <div class="sub">
      {totals.total} entries · {totals.releases} releases · {years.length > 0 ? `${years[years.length-1]}–${years[0]}` : ''} · archive in motion
    </div>
  </header>

  <nav class="filters" id="filters">
    <span class="filters-label">Project</span>
    <button class="filter-btn active" data-axis="project" data-value="all">All</button>
    {projects.map(p => (
      <button class="filter-btn" data-axis="project" data-value={p}>{p}</button>
    ))}
    <span class="group-sep"></span>
    <span class="filters-label">Medium</span>
    <button class="filter-btn active" data-axis="kind" data-value="all">All</button>
    {kinds.map(k => (
      <button class="filter-btn" data-axis="kind" data-value={k}>{k.replace('_', ' ')}</button>
    ))}
  </nav>

  <main class="timeline">
    {years.map(year => (
      <section class="year-row" data-year={year}>
        <div class="year-label">
          {year}
          <span class="after">{byYear.get(year)!.length} entries</span>
        </div>
        <div class="entries">
          {byYear.get(year)!.map(e => (
            <article
              class={`entry size-${e.size}`}
              data-project={e.project}
              data-kind={e.kind}
              data-entry-id={e.id}
            >
              {e.project && <span class="project-tag">{e.project}</span>}
              {e.cover && <img class="cover" src={e.cover} alt="" loading="lazy" />}
              <div>
                <div class="title">{e.title}</div>
                {e.preservedTitle && e.preservedTitle !== e.title && (
                  <div class="preserved">{e.preservedTitle}</div>
                )}
              </div>
              <div class="medium-tag">{e.kind.replace('_', ' ')} · {e.date}</div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </main>

  <footer class="foot">
    CRFW timeline · proof of concept · {totals.total} entries indexed
  </footer>

  <!-- popup shell -->
  <div class="popup-scrim" id="popup-scrim" role="dialog" aria-modal="true" aria-labelledby="popup-title">
    <div class="popup" id="popup"></div>
  </div>

  <!-- data payload for popups (server-rendered JSON) -->
  <script
    id="entry-data"
    type="application/json"
    set:html={JSON.stringify(Object.fromEntries(entries.map(e => [e.id, e])))}
  ></script>

  <script is:inline>
    (function () {
      const raw = document.getElementById('entry-data').textContent;
      const DATA = JSON.parse(raw);
      const scrim = document.getElementById('popup-scrim');
      const popup = document.getElementById('popup');

      function renderPopup(e) {
        const d = e.data || {};
        const cover = e.cover || d.coverArt;
        const trackHtml = (d.tracklist || []).map(t => `
          <li>
            <span class="n">${t.n ?? ''}</span>
            <span>
              <span class="track-title">${escapeHtml(t.title)}</span>
              ${t.preservedTitle && t.preservedTitle !== t.title
                ? `<span class="track-preserved">${escapeHtml(t.preservedTitle)}</span>`
                : ''}
            </span>
          </li>`).join('');
        const summary = d.summary ? `<div class="summary"><p>${escapeHtml(d.summary)}</p></div>` : '';
        const bodyHtml = d.body ? `<div class="summary">${simpleMarkdown(d.body)}</div>` : '';
        const archive = d.archivePath
          ? `<div class="archive-path">📁 ${escapeHtml(d.archivePath)}</div>` : '';
        const meta = [
          d.date || e.date,
          e.project,
          d.format,
          d.era,
          e.kind,
        ].filter(Boolean).map(m => `<span>${escapeHtml(m)}</span>`).join('');

        popup.innerHTML = `
          <button class="popup-close" aria-label="Close" id="popup-close">×</button>
          <div class="popup-header">
            ${cover ? `<img class="popup-cover" src="${cover}" alt="" />` : '<div class="popup-cover"></div>'}
            <div>
              <h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
              ${e.preservedTitle && e.preservedTitle !== e.title
                ? `<div class="popup-preserved">${escapeHtml(e.preservedTitle)}</div>` : ''}
              <div class="popup-meta">${meta}</div>
              ${summary}
            </div>
          </div>
          ${trackHtml ? `<h3>Tracklist</h3><ol class="popup-tracklist">${trackHtml}</ol>` : ''}
          ${bodyHtml ? `<h3>Notes</h3>${bodyHtml}` : ''}
          ${archive ? `<h3>In the archive</h3>${archive}` : ''}
        `;
        document.getElementById('popup-close').addEventListener('click', close);
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[c]));
      }
      function simpleMarkdown(md) {
        // very light — just paragraphs + headings, enough for the PoC
        return md.split(/\n\n+/).map(block => {
          if (block.startsWith('## ')) return `<h4>${escapeHtml(block.slice(3))}</h4>`;
          return `<p>${escapeHtml(block.replace(/\n/g, ' ').trim())}</p>`;
        }).join('');
      }

      function open(id) {
        const e = DATA[id];
        if (!e) return;
        renderPopup(e);
        scrim.setAttribute('open', '');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        scrim.removeAttribute('open');
        document.body.style.overflow = '';
      }
      scrim.addEventListener('click', ev => {
        if (ev.target === scrim) close();
      });
      document.addEventListener('keydown', ev => {
        if (ev.key === 'Escape' && scrim.hasAttribute('open')) close();
      });
      document.querySelectorAll('.entry').forEach(el => {
        el.addEventListener('click', () => open(el.dataset.entryId));
      });

      // Filter tabs — two independent axes (project + kind). AND semantics.
      const state = { project: 'all', kind: 'all' };
      function applyFilters() {
        document.querySelectorAll('.entry').forEach(el => {
          const okProj = state.project === 'all' || el.dataset.project === state.project;
          const okKind = state.kind === 'all' || el.dataset.kind === state.kind;
          el.hidden = !(okProj && okKind);
        });
        // Hide empty year rows
        document.querySelectorAll('.year-row').forEach(row => {
          const visible = row.querySelectorAll('.entry:not([hidden])').length;
          row.style.display = visible ? '' : 'none';
        });
      }
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const axis = btn.dataset.axis;
          const value = btn.dataset.value;
          state[axis] = value;
          document.querySelectorAll(`.filter-btn[data-axis="${axis}"]`)
            .forEach(b => b.classList.toggle('active', b.dataset.value === value));
          applyFilters();
        });
      });
    })();
  </script>
</Base>
