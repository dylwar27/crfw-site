---
import Base from '../layouts/Base.astro';
import TopNav from '../components/TopNav.astro';
import { getCollection } from 'astro:content';
import { renderBody } from '../lib/renderBody';
import articlesData from '../../data/articles-snapshot.json';

const bio = articlesData.sheets['Biographical Summary'] as Array<{ Field: string; Value: string; Source?: string }>;

// Group fields into sections for readability
const sections = [
  { label: 'Identity',       fields: ['Full name', 'Artist names'] },
  { label: 'Life',           fields: ['Born', 'Raised', 'Died'] },
  { label: 'Scene',          fields: ['Home scene', 'Genres', 'Instruments', 'Known for'] },
  { label: 'Work',           fields: ['Active period — alphabets', 'Active period — killd by', 'Voice memo period', 'Meow Wolf installation'] },
  { label: 'Presence',       fields: ['Bandcamp — alphabets', 'Bandcamp — killd by', 'YouTube', 'SoundCloud', 'Contact email (historical)'] },
  { label: 'In memoriam',    fields: ['Memorial fund'] },
];

const fieldMap = Object.fromEntries(bio.map(b => [b.Field, b]));

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

// Pull Colin's vault entry for the rich biographical body. The vault has
// curator-authored prose (era overview, family, collaborators, quotes) that
// shouldn't be agent-rewritten — render it as-is via the wikilink renderer.
const people = await getCollection('vault_people');
const colin = people.find(p => p.id === 'colin-ward');
const colinBodyHtml = colin ? renderBody(colin.data.body || '', BASE) : '';
const aliases = (colin?.data.aliases as string[] | undefined) || [];
const contactPublic = (colin?.data.contact_public as Record<string, string | null>) || {};
const externalLinks = Object.entries(contactPublic)
  .filter(([, v]) => v && String(v).match(/^https?:\/\/|^[\w.-]+\.[a-z]{2,}/i))
  .map(([k, v]) => ({
    label: k.replace(/_/g, ' '),
    url: String(v).startsWith('http') ? String(v) : `https://${v}`,
  }));

// Voice memos: pull the 3 earliest published memos as the "Colin's voice"
// landing strip. Family / first-time visitors should hear him within a
// click. Ordering by date (chronological) is structural, not editorial —
// no curatorial picking. A curator can later add a `featured` tag to bias
// the selection (deferred).
const memos = await getCollection('voice_memos');
const featuredMemos = memos
  .filter(m => m.data.published !== false)
  .sort((a, b) => (a.data.date || '').localeCompare(b.data.date || ''))
  .slice(0, 3)
  .map(m => {
    const slug = m.id.replace(/\.json$/, '');
    return {
      slug,
      date: m.data.date,
      transcript: (m.data.transcript || '').slice(0, 240).trim() + ((m.data.transcript || '').length > 240 ? '…' : ''),
      audioSrc: `${BASE}/media/voice-memos/${slug}.m4a`,
      permalink: `${BASE}/voice-memo/${slug}`,
    };
  });
---
<Base title="About Colin Ward — CRFW">
  <TopNav current="about" />
  <article class="about-page">
    <nav class="about-nav">
      <a href={`${BASE}/`}>← Back to timeline</a>
    </nav>

    <header class="about-header">
      <h1>Colin Richard Ferguson Ward</h1>
      <p class="about-lede">August 29, 1990 — February 1, 2018.</p>
      <p class="about-sub">Musician, producer, percussionist, visual artist. Denver DIY. Known as alphabets (2008–2013) and killd by (2015–2017).</p>
      {aliases.length > 0 && (
        <p class="about-aliases">Also: {aliases.join(' · ')}</p>
      )}
    </header>

    {featuredMemos.length > 0 && (
      <section class="about-section about-voice">
        <h2>Colin's voice</h2>
        <p class="about-voice-lede">
          Three of the earliest preserved voice memos from Colin's iPhone — sketches, freestyles, recorded ideas. <a href={`${BASE}/?kind=voice_memo`}>Hear all {memos.filter(m => m.data.published !== false).length} on the timeline →</a>
        </p>
        <ul class="memo-strip">
          {featuredMemos.map(m => (
            <li class="memo-strip-item">
              <div class="memo-strip-meta">
                <span class="memo-strip-date">{m.date}</span>
                <a class="memo-strip-permalink" href={m.permalink}>permalink ↗</a>
              </div>
              <audio class="memo-strip-audio" controls preload="metadata">
                <source src={m.audioSrc} type="audio/mp4" />
                <source src={m.audioSrc} type="audio/m4a" />
              </audio>
              <div class="memo-strip-transcript">{m.transcript}</div>
            </li>
          ))}
        </ul>
      </section>
    )}

    {colinBodyHtml && (
      <section class="about-section about-bio">
        <h2>Biography</h2>
        <div class="about-bio-body" set:html={colinBodyHtml} />
      </section>
    )}

    {externalLinks.length > 0 && (
      <section class="about-section">
        <h2>Online</h2>
        <ul class="about-links">
          {externalLinks.map(l => (
            <li>
              <span class="about-link-label">{l.label}</span>
              <a href={l.url} target="_blank" rel="noopener">{l.url.replace(/^https?:\/\//, '')}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {sections.map(s => {
      const rows = s.fields.map(f => fieldMap[f]).filter(Boolean);
      if (!rows.length) return null;
      return (
        <section class="about-section">
          <h2>{s.label}</h2>
          <dl>
            {rows.map(r => (
              <>
                <dt>{r.Field}</dt>
                <dd>{r.Value}</dd>
              </>
            ))}
          </dl>
        </section>
      );
    })}

    <section class="about-section">
      <h2>Sources</h2>
      <p class="about-sources">
        EverybodyWiki entry, Westword articles, CRFW Fund documentation,
        and the CRFW Archive INDEX.md. See <a href={`${BASE}/`}>the timeline</a>
        and <a href={`${BASE}/projects`}>associated projects</a> for more.
      </p>
    </section>
  </article>
</Base>

<style>
  .about-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 48px 32px 96px;
    font-family: var(--sans);
  }
  .about-nav {
    margin-bottom: 32px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .about-nav a { color: var(--ink-dim); text-decoration: none; }
  .about-nav a:hover { color: var(--accent-2); }

  .about-header {
    margin-bottom: 64px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 32px;
  }
  .about-header h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 6vw, 68px);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .about-lede {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--accent-2);
    letter-spacing: 0.05em;
    margin: 0 0 12px;
  }
  .about-sub {
    font-family: var(--serif);
    font-size: 19px;
    color: var(--ink-dim);
    line-height: 1.55;
    margin: 0;
  }
  .about-aliases {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-dim);
    margin: 16px 0 0;
    letter-spacing: 0.04em;
  }

  .about-bio-body {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.65;
  }
  .about-bio-body :global(h1),
  .about-bio-body :global(h2),
  .about-bio-body :global(h3) {
    font-family: var(--serif);
    font-weight: 700;
    margin: 32px 0 12px;
    line-height: 1.2;
  }
  .about-bio-body :global(h1) { display: none; }      /* page already has h1 */
  .about-bio-body :global(h2) { font-size: 22px; color: var(--ink); }
  .about-bio-body :global(h3) { font-size: 17px; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.05em; }
  .about-bio-body :global(p) { margin: 0 0 16px; }
  .about-bio-body :global(ul) { padding-left: 20px; margin: 0 0 16px; }
  .about-bio-body :global(blockquote) {
    border-left: 2px solid var(--accent-2);
    margin: 24px 0;
    padding: 6px 0 6px 16px;
    color: var(--ink-dim);
    font-style: italic;
  }
  .about-bio-body :global(.wiki-link) {
    color: var(--accent-2);
    text-decoration: none;
    border-bottom: 1px dotted var(--accent-2);
  }
  .about-bio-body :global(.wiki-chip) {
    display: inline-block;
    padding: 1px 6px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    color: var(--ink-dim);
    font-size: 14px;
    margin: 0 2px;
  }

  .about-links { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .about-links li {
    display: grid; grid-template-columns: 120px 1fr; gap: 16px;
    font-family: var(--mono); font-size: 13px;
  }
  .about-link-label { color: var(--ink-dim); text-transform: capitalize; }
  .about-links a { color: var(--accent-2); }

  .about-voice-lede {
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink-dim);
    line-height: 1.5;
    margin: 0 0 24px;
  }
  .about-voice-lede a { color: var(--accent-2); }
  .memo-strip {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr; gap: 24px;
  }
  .memo-strip-item {
    display: flex; flex-direction: column; gap: 8px;
    padding: 16px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    border-radius: 4px;
  }
  .memo-strip-meta {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--accent-2);
  }
  .memo-strip-permalink { color: var(--ink-dim); text-decoration: none; }
  .memo-strip-permalink:hover { color: var(--accent-2); }
  .memo-strip-audio { width: 100%; margin: 4px 0; }
  .memo-strip-transcript {
    font-family: var(--serif); font-size: 14px; line-height: 1.5;
    color: var(--ink-dim); font-style: italic;
  }

  .about-section {
    margin-bottom: 48px;
  }
  .about-section h2 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 16px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 6px;
  }

  .about-section dl {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 12px 24px;
    margin: 0;
  }
  @media (max-width: 600px) {
    .about-section dl { grid-template-columns: 1fr; gap: 4px 0; }
  }
  .about-section dt {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-dim);
    letter-spacing: 0.05em;
  }
  .about-section dd {
    margin: 0;
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.5;
  }
  @media (max-width: 600px) {
    .about-section dd { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--rule); }
  }
  .about-sources {
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink-dim);
    line-height: 1.55;
  }
  .about-sources a { color: var(--accent-2); }
</style>
