---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { renderBody, renderInline } from '../../lib/renderBody';

export async function getStaticPaths() {
  const venues = await getCollection('vault_venues');
  return venues
    .filter(v => v.data.public_display !== false)
    .map(v => ({
      params: { slug: v.id },
      props: { venue: v },
    }));
}

const { venue } = Astro.props;
const d = venue.data;

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

const [allPeople, allProjects] = await Promise.all([
  getCollection('vault_people'),
  getCollection('vault_projects'),
]);

function refSlug(ref: string | undefined) {
  if (!ref) return '';
  return String(ref).split('/').at(-1) ?? '';
}

// Related people and projects from the `related` field
const relatedRefs: string[] = d.related || [];
const relatedPeople = allPeople.filter(p => relatedRefs.map(refSlug).includes(p.id));
const relatedProjects = allProjects.filter(p => relatedRefs.map(refSlug).includes(p.id));

const name = d.name || d.title || venue.id;
const bodyHtml = renderBody(d.body || '', BASE);

function venueKindLabel(k: string | undefined): string {
  if (!k) return '';
  return k.replace(/_/g, ' ');
}
---
<Base title={`${name} — CRFW`}>
  <article class="venue-page">
    <nav class="venue-nav">
      <a href={`${BASE}/`}>← Timeline</a>
      <span class="sep">·</span>
      <a href={`${BASE}/venues`}>All venues</a>
    </nav>

    <header class="venue-header">
      <div class="venue-kind">{venueKindLabel(d.venue_kind) || 'venue'}</div>
      <h1>{name}</h1>

      {(d.city || d.region) && (
        <div class="venue-location">
          {[d.address, d.city, d.region].filter(Boolean).join(', ')}
        </div>
      )}

      {(d.opened_year || d.closed_year) && (
        <div class="venue-dates">
          {d.opened_year && <span>{d.opened_year}</span>}
          {d.opened_year && (d.closed_year || d.status === 'closed') && <span class="date-sep"> – </span>}
          {d.closed_year
            ? <span>{d.closed_year}</span>
            : d.status === 'active'
              ? <span>present</span>
              : null
          }
          {d.status && (
            <span class={`venue-status venue-status--${d.status}`}>{d.status}</span>
          )}
        </div>
      )}
    </header>

    {relatedPeople.length > 0 && (
      <section class="venue-section">
        <h2>People</h2>
        <ul class="venue-related">
          {relatedPeople.map(p => (
            <li>
              <a href={`${BASE}/person/${p.id}`} class="related-link">
                {p.data.display_name || p.data.title || p.id}
              </a>
              {p.data.role_summary && (
                <span class="related-role">{p.data.role_summary}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedProjects.length > 0 && (
      <section class="venue-section">
        <h2>Projects</h2>
        <ul class="venue-related">
          {relatedProjects.map(p => (
            <li>
              <a href={`${BASE}/project/${p.id}`} class="related-link">
                {p.data.name || p.data.title || p.id}
              </a>
              {p.data.formed_year && (
                <span class="related-role">
                  {p.data.formed_year}{p.data.dissolved_year ? `–${p.data.dissolved_year}` : ''}
                </span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {d.website && (
      <section class="venue-section">
        <h2>Links</h2>
        <ul class="venue-links">
          <li><a href={d.website} target="_blank" rel="noopener">{d.website.replace(/^https?:\/\//, '')}</a></li>
        </ul>
      </section>
    )}

    {bodyHtml && (
      <section class="venue-body" set:html={bodyHtml} />
    )}
  </article>
</Base>

<style>
  .venue-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 48px 32px 96px;
    font-family: var(--sans);
  }
  .venue-nav {
    margin-bottom: 32px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .venue-nav a { color: var(--ink-dim); text-decoration: none; }
  .venue-nav a:hover { color: var(--accent-2); }
  .venue-nav .sep { color: var(--rule); margin: 0 8px; }

  .venue-header {
    margin-bottom: 48px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 32px;
  }
  .venue-kind {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-2);
    margin-bottom: 8px;
  }
  .venue-header h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .venue-location {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-dim);
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }
  .venue-dates {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-dim);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .date-sep { color: var(--rule); }
  .venue-status {
    margin-left: 10px;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 3px;
  }
  .venue-status--closed { background: rgba(255,100,80,0.12); color: #e05040; }
  .venue-status--active { background: rgba(100,200,100,0.12); color: #60b060; }

  .venue-section { margin-bottom: 40px; }
  .venue-section h2 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0 0 16px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 6px;
  }

  .venue-related { list-style: none; padding: 0; margin: 0; }
  .venue-related li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 6px 0;
    border-bottom: 1px solid var(--rule);
  }
  .related-link {
    font-family: var(--serif);
    font-size: 17px;
    color: inherit;
    text-decoration: none;
    flex-shrink: 0;
  }
  .related-link:hover { color: var(--accent-2); }
  .related-role {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-dim);
  }

  .venue-links { list-style: none; padding: 0; margin: 0; }
  .venue-links li { padding: 4px 0; font-family: var(--mono); font-size: 13px; }
  .venue-links a { color: var(--accent-2); text-decoration: none; }
  .venue-links a:hover { text-decoration: underline; }

  /* Body prose — same pattern as person-body */
  .venue-body {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
  }
  .venue-body :global(p) { margin: 0 0 1em; }
  .venue-body :global(h4),
  .venue-body :global(h5) {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 2em 0 0.6em;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--rule);
  }
  .venue-body :global(blockquote) {
    border-left: 3px solid var(--accent-2);
    margin: 1em 0;
    padding: 0 0 0 16px;
    color: var(--ink-dim);
    font-style: italic;
  }
  .venue-body :global(ul) { padding-left: 1.4em; margin: 0 0 1em; }
  .venue-body :global(li) { margin-bottom: 0.3em; }
  .venue-body :global(.wiki-link) { color: var(--accent-2); text-decoration: none; }
  .venue-body :global(.wiki-link:hover) { text-decoration: underline; }
  .venue-body :global(.wiki-chip) {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--ink-dim);
    background: var(--surface-2, rgba(255,255,255,0.05));
    padding: 1px 5px;
    border-radius: 3px;
  }
  .venue-body :global(a) { color: var(--accent-2); text-decoration: none; }
  .venue-body :global(a:hover) { text-decoration: underline; }
  .venue-body :global(strong) { font-weight: 700; }
</style>
