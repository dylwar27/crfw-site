---
import Base from '../../layouts/Base.astro';
import TopNav from '../../components/TopNav.astro';
import { getCollection } from 'astro:content';

const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

const articles = (await getCollection('vault_press'))
  .filter(a => a.data.public_display !== false)
  .sort((a, b) => {
    const da = String(a.data.published_date || a.data.date || '0000');
    const db = String(b.data.published_date || b.data.date || '0000');
    return db.localeCompare(da); // newest first
  });

function pubName(a: any): string {
  if (a.data.publication_name) return a.data.publication_name;
  if (a.data.publication) return String(a.data.publication).split('/').at(-1)?.replace(/-/g, ' ') ?? '';
  return '';
}

function dateDisplay(a: any): string {
  const d = String(a.data.published_date || a.data.date || '');
  if (!d || d === 'undefined') return '—';
  if (d.length >= 7) return d.slice(0, 7); // YYYY-MM
  return d.slice(0, 4); // YYYY
}
---
<Base title="Press — CRFW">
  <TopNav current="press" />
  <div class="press-page">
    <nav class="press-nav">
      <a href={`${BASE}/`}>← Timeline</a>
    </nav>

    <header class="press-header">
      <div class="press-eyebrow">Archive</div>
      <h1>Press</h1>
      <p class="press-sub">{articles.length} articles, obits, and features</p>
    </header>

    <table class="press-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Title</th>
          <th>Publication</th>
          <th>Kind</th>
        </tr>
      </thead>
      <tbody>
        {articles.map(a => (
          <tr>
            <td class="col-date">{dateDisplay(a)}</td>
            <td class="col-title">
              <a href={`${BASE}/press/${a.id}`}>{a.data.title}</a>
              {a.data.colin_specific && <span class="colin-dot" title="Colin-specific">●</span>}
            </td>
            <td class="col-pub">{pubName(a)}</td>
            <td class="col-kind">{a.data.press_kind || ''}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .press-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 32px 96px;
    font-family: var(--sans);
  }
  .press-nav {
    margin-bottom: 32px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .press-nav a { color: var(--ink-dim); text-decoration: none; }
  .press-nav a:hover { color: var(--accent-2); }

  .press-header { margin-bottom: 40px; border-bottom: 1px solid var(--rule); padding-bottom: 28px; }
  .press-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-2);
    margin-bottom: 8px;
  }
  .press-header h1 {
    font-family: var(--serif);
    font-size: clamp(40px, 7vw, 84px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .press-sub { font-family: var(--mono); font-size: 13px; color: var(--ink-dim); margin: 0; }

  .press-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .press-table thead th {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-dim);
    text-align: left;
    padding: 0 12px 10px 0;
    border-bottom: 1px solid var(--rule);
  }
  .press-table tbody tr { border-bottom: 1px solid var(--rule); }
  .press-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
  .press-table td { padding: 9px 12px 9px 0; vertical-align: baseline; }

  .col-date { font-family: var(--mono); font-size: 12px; color: var(--ink-dim); white-space: nowrap; width: 80px; }
  .col-title { font-family: var(--serif); font-size: 16px; }
  .col-title a { color: inherit; text-decoration: none; }
  .col-title a:hover { color: var(--accent-2); }
  .col-pub { font-family: var(--mono); font-size: 11px; color: var(--ink-dim); width: 160px; }
  .col-kind { font-family: var(--mono); font-size: 10px; color: var(--accent-2); letter-spacing: 0.12em; text-transform: uppercase; width: 80px; white-space: nowrap; }

  .colin-dot {
    margin-left: 6px;
    font-size: 8px;
    color: var(--accent-2);
    vertical-align: middle;
  }

  @media (max-width: 600px) {
    .press-table { font-size: 13px; }
    .col-pub, .col-kind { display: none; }
  }
</style>
