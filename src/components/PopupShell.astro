---
/**
 * PopupShell.astro — shared popup + inline-play behavior for the timeline,
 * the motif walk, and any future page that uses .entry cards.
 *
 * Renders:
 *   - the #site-config + #entry-data JSON payloads the popup script reads
 *   - the popup scrim + popup div
 *   - the popup script (renderPopup, findRelated, simpleMarkdown, etc.)
 *   - delegated click handlers for `.entry`, `.yt-inline-play`, `.bc-inline-play`
 *
 * Click handlers are document-delegated (not per-element bindings), so the
 * walk page can append cards dynamically and they pick up the same behavior
 * without re-wiring. The timeline page works identically — its cards just
 * happen to all exist at script-init time.
 *
 * Public API surfaced on window:
 *   window.__crfwOpenPopup(entryId)   — open a popup for a given entry id.
 */
type Entries = Record<string, any>;

interface Props {
  entries: Entries;
}

const { entries } = Astro.props as Props;
const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
---

<!-- popup shell -->
<div class="popup-scrim" id="popup-scrim" role="dialog" aria-modal="true" aria-labelledby="popup-title">
  <div class="popup" id="popup"></div>
</div>

<!-- data payload for popups (server-rendered JSON) -->
<script id="site-config" type="application/json" data-pagefind-ignore set:html={JSON.stringify({ base: BASE })}></script>
<script
  id="entry-data"
  type="application/json"
  data-pagefind-ignore
  set:html={JSON.stringify(entries)}
></script>

<script is:inline>
  (function () {
    const raw = document.getElementById('entry-data').textContent;
    const DATA = JSON.parse(raw);
    const scrim = document.getElementById('popup-scrim');
    const popup = document.getElementById('popup');

    // --- Relation derivation ---
    function findRelated(entry) {
      const results = [];
      const seen = new Set([entry.id]);
      function push(other, reason) {
        if (seen.has(other.id)) return;
        seen.add(other.id);
        results.push({ entry: other, reason });
      }
      const d = entry.data || {};
      for (const refList of [d.relatedPhotos, d.relatedVideos, d.relatedVoiceMemos, d.relatedLyrics]) {
        if (!Array.isArray(refList)) continue;
        for (const ref of refList) {
          const id = ref?.id || ref;
          if (typeof id !== 'string') continue;
          for (const [key, val] of Object.entries(DATA)) {
            if (key.endsWith(id)) push(val, 'linked');
          }
        }
      }
      const GENERIC_TITLES = new Set(['untitled', 'recovery', 'alphabets', 'remix', 'demo', 'mix', 'video']);
      const titleNorm = (entry.title || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
      if (titleNorm.length >= 6 && !GENERIC_TITLES.has(titleNorm)) {
        for (const other of Object.values(DATA)) {
          if (other.id === entry.id) continue;
          const otherNorm = (other.title || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
          if (otherNorm === titleNorm) push(other, 'same title');
        }
      }
      if (entry.project && entry.year) {
        for (const other of Object.values(DATA)) {
          if (other.id === entry.id) continue;
          if (other.project !== entry.project) continue;
          if (other.year !== entry.year) continue;
          push(other, 'same project + year');
        }
      }
      return results.slice(0, 8);
    }

    function renderRelated(entry) {
      const related = findRelated(entry);
      if (!related.length) return '';
      const items = related.map(({ entry: r, reason }) => `
        <button class="related-chip" data-entry-id="${escapeHtml(r.id)}" title="${escapeHtml(reason)}">
          <span class="related-kind">${escapeHtml(r.kind.replace('_', ' '))}</span>
          <span class="related-title">${escapeHtml(r.title)}</span>
          <span class="related-date">${escapeHtml(r.date || '')}</span>
        </button>
      `).join('');
      return `<h3>Related in the archive</h3><div class="related-list">${items}</div>`;
    }

    function renderPopup(e) {
      const d = e.data || {};

      // ── DIMCP chunk popup ──
      if (e.kind === 'dimcp_chunk') {
        const epRows = (d.episodes || []).map(ep => {
          const vidUrl = ep.permalink || `${BASE_URL}/video/${escapeHtml(ep.slug)}`;
          return `<li class="popup-ep-row">
            <a href="${vidUrl}" class="popup-ep-link">
              <span class="popup-ep-num">${escapeHtml(ep.title.match(/EP_?(\d+)/i)?.[0] ?? ep.title)}</span>
              <span class="popup-ep-excerpt">${escapeHtml(ep.transcript || ep.title)}</span>
              <span class="popup-ep-arrow">→</span>
            </a>
          </li>`;
        }).join('');
        popup.innerHTML = `
          <button class="popup-close" aria-label="Close" id="popup-close">×</button>
          <div class="popup-header">
            <div class="dimcp-popup-icon">🎬</div>
            <div>
              <h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
              <div class="popup-meta"><span>Dog is My Copilot</span><span>${escapeHtml(d.label || '')}</span><span>${(d.episodes||[]).length} episodes</span></div>
            </div>
          </div>
          <ol class="popup-ep-list">${epRows}</ol>
        `;
        popup.querySelector('#popup-close').addEventListener('click', close);
        return;
      }

      // ── Voice memo group popup ──
      if (e.kind === 'voice_memo_group') {
        const memos = d.memos || [];
        const firstSlug = memos[0]?.slug || '';
        const firstAudio = `${BASE_URL}/media/voice-memos/${escapeHtml(firstSlug)}.m4a`;
        const memoRows = memos.map((m, i) => {
          const audioSrc = `${BASE_URL}/media/voice-memos/${escapeHtml(m.slug)}.m4a`;
          const href = m.permalink || `${BASE_URL}/voice-memo/${escapeHtml(m.slug)}`;
          return `<li class="popup-ep-row vmemo-row${i === 0 ? ' active' : ''}" data-audio-src="${audioSrc}" data-permalink="${href}" data-transcript="${escapeHtml(m.transcript || m.title)}">
            <button class="popup-ep-link vmemo-pick" type="button">
              <span class="popup-ep-excerpt">${escapeHtml(m.transcript || m.title)}</span>
              <span class="popup-ep-arrow" aria-hidden="true">▶</span>
            </button>
            <a href="${href}" class="vmemo-permalink" title="Open full transcript page">↗</a>
          </li>`;
        }).join('');
        popup.innerHTML = `
          <button class="popup-close" aria-label="Close" id="popup-close">×</button>
          <div class="popup-header popup-header-vmemo">
            <div class="popup-vmemo-player">
              <div class="popup-vmemo-mono">VOICE MEMO · ${escapeHtml((memos[0]?.slug || '').slice(0, 8).replace(/^(\d{4})(\d{2})(\d{2})$/, '$1-$2-$3'))}</div>
              <audio class="popup-audio" id="vmemo-audio" controls preload="metadata">
                <source src="${firstAudio}" type="audio/mp4" />
                <source src="${firstAudio}" type="audio/m4a" />
                Audio not available.
              </audio>
              <div class="popup-vmemo-current" id="vmemo-transcript">${escapeHtml(memos[0]?.transcript || '')}</div>
            </div>
            <div class="popup-vmemo-meta">
              <h2 class="popup-title" id="popup-title">${escapeHtml(d.label || e.title)}</h2>
              <div class="popup-meta"><span>voice memos</span><span>${memos.length} recording${memos.length === 1 ? '' : 's'}</span></div>
            </div>
          </div>
          <ol class="popup-ep-list popup-vmemo-list">${memoRows}</ol>
        `;
        popup.querySelector('#popup-close').addEventListener('click', close);
        const audioEl = popup.querySelector('#vmemo-audio');
        const transcriptEl = popup.querySelector('#vmemo-transcript');
        popup.querySelectorAll('.vmemo-row').forEach(row => {
          const pick = row.querySelector('.vmemo-pick');
          if (!pick) return;
          pick.addEventListener('click', () => {
            const src = row.dataset.audioSrc;
            const text = row.dataset.transcript || '';
            if (audioEl) {
              const sources = audioEl.querySelectorAll('source');
              sources.forEach(s => { s.setAttribute('src', src); });
              audioEl.load();
              audioEl.play().catch(() => { /* user-gesture variations */ });
            }
            if (transcriptEl) transcriptEl.textContent = text;
            popup.querySelectorAll('.vmemo-row').forEach(r => r.classList.remove('active'));
            row.classList.add('active');
          });
        });
        return;
      }

      // ── Photo carousel popup ──
      if (e.kind === 'photo_carousel') {
        const photos = d.photos || [];
        const thumbs = photos.map((p, i) =>
          `<button class="carousel-grid-thumb${i === 0 ? ' active' : ''}" data-idx="${i}" style="background-image:url('${escapeHtml(p.src || '')}')"></button>`
        ).join('');
        const firstSrc = photos[0]?.src || '';
        popup.innerHTML = `
          <button class="popup-close" aria-label="Close" id="popup-close">×</button>
          <div class="popup-header">
            <div><h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
              <div class="popup-meta"><span>${photos.length} photo${photos.length===1?'':'s'}</span><span>${e.year}</span></div>
            </div>
          </div>
          <div class="popup-photo-main">
            <img id="carousel-main-img" src="${escapeHtml(firstSrc)}" alt="" />
            <p id="carousel-main-cap" class="carousel-main-cap">${escapeHtml(photos[0]?.caption || '')}</p>
          </div>
          <div class="carousel-grid-strip">${thumbs}</div>
        `;
        popup.querySelector('#popup-close').addEventListener('click', close);
        const mainImg = popup.querySelector('#carousel-main-img');
        const mainCap = popup.querySelector('#carousel-main-cap');
        popup.querySelectorAll('.carousel-grid-thumb').forEach(btn => {
          btn.addEventListener('click', () => {
            const idx = +btn.dataset.idx;
            const p = photos[idx];
            if (!p) return;
            mainImg.src = p.src || '';
            mainCap.textContent = p.caption || '';
            popup.querySelectorAll('.carousel-grid-thumb').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
          });
        });
        return;
      }

      const cover = e.cover || d.coverArt;
      const photoSrcs = e.kind === 'photo' && d.src
        ? [d.src, ...(d.carouselExtras || [])]
        : [];
      const isPhotoCarousel = photoSrcs.length > 1;
      const isVisualArt = e.kind === 'photo' && (e.tags || []).includes('visual-art');

      let leftColHtml;
      if (photoSrcs.length > 0) {
        const imgClass = isVisualArt ? 'popup-cover popup-cover-art' : 'popup-cover';
        leftColHtml = `<div class="popup-carousel-wrap${isVisualArt ? ' popup-art-wrap' : ''}">
          <a href="${escapeHtml(photoSrcs[0])}" target="_blank" rel="noopener" class="popup-art-link" title="Open at original size in new tab">
            <img class="${imgClass}" id="carousel-img" src="${escapeHtml(photoSrcs[0])}" alt="" />
          </a>
          ${isPhotoCarousel ? `<div class="carousel-nav">
            <button class="carousel-btn" id="carousel-prev" aria-label="Previous" disabled>‹</button>
            <span class="carousel-counter" id="carousel-counter">1 / ${photoSrcs.length}</span>
            <button class="carousel-btn" id="carousel-next" aria-label="Next">›</button>
          </div>` : ''}
        </div>`;
      } else if (e.kind === 'video' && d.localSrc) {
        leftColHtml = `<video class="popup-cover popup-video" controls preload="none"${d.poster ? ` poster="${escapeHtml(d.poster)}"` : ''}>
          <source src="${escapeHtml(d.localSrc)}" type="video/mp4" />
        </video>`;
      } else if (e.kind === 'voice_memo') {
        const memoSlug = String(e.id).replace(/^voice--/, '').replace(/\.json$/, '');
        const audioSrc = `${BASE_URL}/media/voice-memos/${memoSlug}.m4a`;
        leftColHtml = `<div class="popup-cover popup-audio-wrap">
          <div class="popup-audio-mono">VOICE MEMO · ${escapeHtml(e.date.slice(0, 10))}</div>
          <audio class="popup-audio" controls preload="none">
            <source src="${escapeHtml(audioSrc)}" type="audio/mp4" />
            <source src="${escapeHtml(audioSrc)}" type="audio/m4a" />
            Audio not available.
          </audio>
        </div>`;
      } else {
        leftColHtml = cover ? `<img class="popup-cover" src="${escapeHtml(cover)}" alt="" />` : `<div class="popup-cover"></div>`;
      }

      const trackHtml = (d.tracklist || []).map(t => `
        <li>
          <span class="n">${t.n ?? ''}</span>
          <span>
            <span class="track-title">${escapeHtml(t.title)}</span>
            ${t.preservedTitle && t.preservedTitle !== t.title
              ? `<span class="track-preserved">${escapeHtml(t.preservedTitle)}</span>`
              : ''}
          </span>
        </li>`).join('');

      const transcriptHtml = d.transcript
        ? `<h3>Transcript</h3>
           <div class="summary"><p>${escapeHtml(d.transcript)}</p></div>
           ${d.permalink && d.transcriptFull
             ? `<a class="popup-permalink" href="${d.permalink}">Read full transcript →</a>`
             : ''}`
        : '';

      const locationHtml = d.location
        ? `<div class="popup-meta"><span>📍 ${escapeHtml(d.location)}</span></div>`
        : '';

      const captionHtml = d.caption
        ? `<div class="summary"><p>${escapeHtml(d.caption)}</p></div>`
        : '';

      const urlHtml = d.url
        ? `<a class="popup-permalink" href="${escapeHtml(d.url)}" target="_blank" rel="noopener">Read the article →</a>`
        : '';

      const embedLinks = [];
      let primaryEmbedHtml = '';
      if (d.bandcampItemId) {
        const itemType = d.bandcampItemType === 'track' ? 't' : 'a';
        const src = `https://bandcamp.com/EmbeddedPlayer/${itemType}=${escapeHtml(d.bandcampItemId)}/size=large/bgcol=0e0e12/linkcol=ffd166/transparent=true/`;
        primaryEmbedHtml = `<h3>Listen on Bandcamp</h3>
          <div class="embed-wrap"><iframe class="embed-bandcamp" src="${src}" seamless loading="lazy"></iframe></div>`;
      } else if (d.youtubeId) {
        primaryEmbedHtml = `<h3>Watch on YouTube</h3>
          <div class="embed-wrap"><iframe class="embed-youtube" src="https://www.youtube.com/embed/${escapeHtml(d.youtubeId)}" allowfullscreen loading="lazy"></iframe></div>`;
      } else if (d.soundcloudUrl) {
        const src = `https://w.soundcloud.com/player/?url=${encodeURIComponent(d.soundcloudUrl)}&color=%23ffd166&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
        primaryEmbedHtml = `<h3>Listen on SoundCloud</h3>
          <div class="embed-wrap"><iframe class="embed-soundcloud" src="${src}" loading="lazy"></iframe></div>`;
      }
      if (d.bandcampUrl) embedLinks.push(`<a href="${escapeHtml(d.bandcampUrl)}" target="_blank" rel="noopener" class="embed-link">Bandcamp ↗</a>`);
      if (d.youtubeId) embedLinks.push(`<a href="https://www.youtube.com/watch?v=${escapeHtml(d.youtubeId)}" target="_blank" rel="noopener" class="embed-link">YouTube ↗</a>`);
      if (d.soundcloudUrl) embedLinks.push(`<a href="${escapeHtml(d.soundcloudUrl)}" target="_blank" rel="noopener" class="embed-link">SoundCloud ↗</a>`);
      const embedLinksHtml = embedLinks.length > 1
        ? `<div class="embed-links">${embedLinks.join('')}</div>`
        : '';

      const summary = d.summary ? `<div class="summary"><p>${escapeHtml(d.summary)}</p></div>` : '';
      const bodyHtml = d.body ? `<div class="summary">${simpleMarkdown(d.body)}</div>` : '';
      const archive = d.archivePath
        ? `<div class="archive-path">📁 ${escapeHtml(d.archivePath)}</div>` : '';
      const meta = [
        d.date || e.date,
        e.project,
        d.format,
        d.era,
        e.kind,
      ].filter(Boolean).map(m => `<span>${escapeHtml(m)}</span>`).join('');

      popup.innerHTML = `
        <button class="popup-close" aria-label="Close" id="popup-close">×</button>
        <div class="popup-header${isVisualArt ? ' popup-header-art' : ''}">
          ${leftColHtml}
          <div>
            <h2 class="popup-title" id="popup-title">${escapeHtml(e.title)}</h2>
            ${e.preservedTitle && e.preservedTitle !== e.title
              ? `<div class="popup-preserved">${escapeHtml(e.preservedTitle)}</div>` : ''}
            <div class="popup-meta">${meta}</div>
            ${locationHtml}
            ${summary}
            ${captionHtml}
            ${urlHtml}
          </div>
        </div>
        ${primaryEmbedHtml}
        ${embedLinksHtml}
        ${trackHtml ? `<h3>Tracklist</h3><ol class="popup-tracklist">${trackHtml}</ol>` : ''}
        ${transcriptHtml}
        ${bodyHtml ? `<h3>Notes</h3>${bodyHtml}` : ''}
        ${renderRelated(e)}
        ${archive ? `<h3>In the archive</h3>${archive}` : ''}
      `;
      popup.querySelector('#popup-close').addEventListener('click', close);

      if (isPhotoCarousel) {
        let idx = 0;
        const imgEl = popup.querySelector('#carousel-img');
        const counter = popup.querySelector('#carousel-counter');
        const prevBtn = popup.querySelector('#carousel-prev');
        const nextBtn = popup.querySelector('#carousel-next');
        function goTo(n) {
          idx = n;
          imgEl.src = photoSrcs[idx];
          counter.textContent = `${idx + 1} / ${photoSrcs.length}`;
          prevBtn.disabled = idx === 0;
          nextBtn.disabled = idx === photoSrcs.length - 1;
        }
        prevBtn.addEventListener('click', () => { if (idx > 0) goTo(idx - 1); });
        nextBtn.addEventListener('click', () => { if (idx < photoSrcs.length - 1) goTo(idx + 1); });
      }

      popup.querySelectorAll('.related-chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const id = chip.dataset.entryId;
          if (id && DATA[id]) {
            renderPopup(DATA[id]);
            popup.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      });
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[c]));
    }
    const WIKI_ROUTES = { people: '/person', projects: '/project', press: '/press', venues: '/venue', organizations: '/org' };
    const BASE_URL = (JSON.parse(document.getElementById('site-config').textContent || '{}').base || '');
    function resolveWikilink(ref, label) {
      const parts = ref.trim().split('/');
      const coll = parts.length >= 2 ? parts[0] : '';
      const slug = parts.length >= 2 ? parts.slice(1).join('/') : parts[0];
      const display = escapeHtml(label || slug.replace(/-/g, ' '));
      const route = WIKI_ROUTES[coll];
      if (route) return `<a href="${BASE_URL}${route}/${escapeHtml(slug)}" class="wiki-link">${display}</a>`;
      return `<span class="wiki-chip">${display}</span>`;
    }
    function inlineMd(s) {
      const tokens = [];
      const stash = html => { const k = `\x00${tokens.length}\x00`; tokens.push(html); return k; };
      s = s.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, ref, lbl) => stash(resolveWikilink(ref, lbl?.trim() ?? '')));
      s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, (_, lbl, url) => stash(`<a href="${escapeHtml(url)}" target="_blank" rel="noopener">${escapeHtml(lbl)}</a>`));
      s = s.replace(/\*\*([^*\x00]+?)\*\*/g, (_, t) => stash(`<strong>${escapeHtml(t)}</strong>`));
      s = s.replace(/\*([^*\x00]+?)\*/g, (_, t) => stash(`<em>${escapeHtml(t)}</em>`));
      return escapeHtml(s).replace(/\x00(\d+)\x00/g, (_, i) => tokens[+i]);
    }
    function simpleMarkdown(md) {
      return md.split(/\n\n+/).map(block => {
        const t = block.trim();
        if (!t) return '';
        const hm = t.match(/^(#{1,4})\s+(.+)$/);
        if (hm) return `<h4>${escapeHtml(hm[2])}</h4>`;
        if (t.startsWith('> ')) return `<blockquote>${inlineMd(t.replace(/^> ?/gm,''))}</blockquote>`;
        if (/^[-*] /.test(t)) {
          const lis = t.split('\n').filter(l => /^[-*] /.test(l.trim()))
            .map(l => `<li>${inlineMd(l.replace(/^[-*] /,''))}</li>`).join('');
          return `<ul>${lis}</ul>`;
        }
        return `<p>${inlineMd(t.replace(/\n/g,' '))}</p>`;
      }).filter(Boolean).join('');
    }

    function open(id) {
      const e = DATA[id];
      if (!e) return;
      renderPopup(e);
      scrim.setAttribute('open', '');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      scrim.removeAttribute('open');
      document.body.style.overflow = '';
    }

    // Expose for direct invocation from other scripts (e.g., walk page card click).
    window.__crfwOpenPopup = open;

    scrim.addEventListener('click', ev => {
      if (ev.target === scrim) close();
    });
    document.addEventListener('keydown', ev => {
      if (ev.key === 'Escape' && scrim.hasAttribute('open')) close();
    });

    // Document-delegated clicks so dynamically-appended cards (walk page) work
    // alongside server-rendered ones (timeline). Inline-play handlers run
    // first and stop propagation; otherwise the .entry handler opens the popup.
    document.addEventListener('click', ev => {
      const ytWrap = ev.target.closest && ev.target.closest('.yt-inline-play');
      if (ytWrap) {
        if (ytWrap.dataset.activated === 'true') return;
        const ytId = ytWrap.dataset.ytId;
        if (!ytId) return;
        ev.stopPropagation();
        const title = ytWrap.dataset.ytTitle || '';
        ytWrap.dataset.activated = 'true';
        ytWrap.innerHTML = `<iframe class="yt-inline-iframe"
          src="https://www.youtube.com/embed/${escapeHtml(ytId)}?autoplay=1&rel=0"
          title="${escapeHtml(title)}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>`;
        return;
      }
      const bcWrap = ev.target.closest && ev.target.closest('.bc-inline-play');
      if (bcWrap) {
        if (bcWrap.dataset.activated === 'true') return;
        const itemId = bcWrap.dataset.bcItemId;
        if (!itemId) return;
        ev.stopPropagation();
        const itemType = bcWrap.dataset.bcItemType || 'album';
        const title = bcWrap.dataset.bcTitle || '';
        bcWrap.dataset.activated = 'true';
        bcWrap.innerHTML = `<iframe class="bc-inline-iframe"
          src="https://bandcamp.com/EmbeddedPlayer/${itemType}=${escapeHtml(itemId)}/size=large/bgcol=181a1b/linkcol=64b5f6/transparent=true/"
          seamless title="${escapeHtml(title)}"></iframe>`;
        return;
      }
      const entry = ev.target.closest && ev.target.closest('.entry');
      if (entry && entry.dataset.entryId) {
        open(entry.dataset.entryId);
      }
    });
  })();
</script>
